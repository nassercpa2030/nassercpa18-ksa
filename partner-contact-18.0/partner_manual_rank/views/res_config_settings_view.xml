        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <block name="contacts_setting_container" position="inside">
                <setting
                    help="Automatically rank partners when sale or purchase invoices are posted"
                    groups="base.group_system"
                    title="Automatically rank partners as customers or suppliers"
                    id="partner_rank_auto"
                >
                    <field name="partner_rank_auto" />
                </setting>
            </block>
        </field>
    </record>
</odoo>
