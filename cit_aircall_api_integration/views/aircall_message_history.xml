<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_aircall_message_list" model="ir.ui.view">
        <field name="name">aircall.message.kanban</field>
        <field name="model">aircall.message.history</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="partner_id"/>
                <field name="user_name"/>
                <field name="external_number" string="Number"/>
                <field name="body" string="Message"/>
                <field name="status"/>
                <field name="timestamp" string="Time"/>
                <field name="user_email"/>
            </list>
        </field>
    </record>

    <record id="action_aircall_message_history" model="ir.actions.act_window">
        <field name="name">Aircall Message History</field>
        <field name="res_model">aircall.message.history</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="cit_aircall_api_integration.view_aircall_message_list"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No messages to display.
            </p>
        </field>
    </record>

    <menuitem id="menu_item_aircall_message_history"
              name="Message History"
              action="action_aircall_message_history"
              parent="menu_item_aircall_details_root"
              sequence="2"
    />

</odoo>
