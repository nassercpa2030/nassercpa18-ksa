<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_data_post_contact_to_aircall" model="ir.cron">
            <field name="name">Export Contacts from Odoo to Aircall</field>
            <field name="model_id" ref="model_aircall_connection"/>
            <field name="state">code</field>
            <field name="code">model.post_contacts(limit=55)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="interval_number">1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_partner_phone_format" model="ir.cron">
            <field name="name">Format Partner Phone Numbers</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._cron_format_partner_phone()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
