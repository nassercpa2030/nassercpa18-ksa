<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="odoo_ai_agent_ai_email_matrix_form_view" model="ir.ui.view">
        <field name="name">odoo_ai_agent_ai_email_matrix.form.view</field>
        <field name="model">ai.email.matrix</field>
        <field name="arch" type="xml">
            <form>
                <header>
<!--                    <button name="fetch_email_from_server" type="object" string="Fetch Email" class="btn btn-secondary"/>-->
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="agent_id"/>
                            <field name="vendor_id"/>
                            <field name="topics" />
                            <field name="query" />
                            <field name="full_response" />
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="average_score" />
                        </group>
                    </group>
                    <notebook>
                        <page string="AI Email Matrix Line">
                            <field name="ai_email_matrix_line_ids">
                                <list editable="top" default_order="id desc">
                                    <field name="score_type"/>
                                    <field name="justification" />
                                    <field name="score"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="odoo_ai_agent_ai_email_matrix_list_view" model="ir.ui.view">
       <field name="name">odoo_ai_agent_ai_email_matrix.view.list</field>
       <field name="model">ai.email.matrix</field>
       <field name="arch" type="xml">
           <list>
               <field name="agent_id"/>
               <field name="vendor_id"/>
               <field name="date_from" />
               <field name="date_to" />
               <field name="average_score" />
               <field name="topics" />
           </list>
       </field>
    </record>


    <record id="action_odoo_ai_agent_ai_email_matrix" model="ir.actions.act_window">
       <field name="name">AI Email Matrix</field>
       <field name="res_model">ai.email.matrix</field>
       <field name="view_mode">list,form</field>
       <field name="help" type="html">
           <p class="o_view_nocontent_smiling_face">
               Create AI Email Matrix
           </p>
       </field>
    </record>

</odoo>