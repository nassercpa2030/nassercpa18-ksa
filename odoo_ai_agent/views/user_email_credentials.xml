<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="user_email_credentials_form_view" model="ir.ui.view">
        <field name="name">user.email.credentials.form</field>
        <field name="model">user.email.credentials</field>
        <field name="arch" type="xml">
            <form string="User Email Credentials">
                <sheet>
                    <group>
                        <group string="Server Information">
                            <field name="server"/>
                            <field name="port" options="{'format': false}"/>
                            <field name="is_ssl"/>
                            <field name="user_smtp_status"
                                       widget="badge"
                                       readonly="1"
                                       class="mr2"
                                       decoration-success="user_smtp_status == 'connected'"
                                       decoration-danger="user_smtp_status == 'disconnected'"/>
                            <button name="test_mail_server_connection" colspan="2"
                                    string="Test Connection"
                                    type="object"
                                    class="btn-primary"/>
                        </group>
                        <group string="Login Information">
                            <field name="user"/>
                            <field name="password" password="True"/>
                            <field name="user_id" string="User ID"/>
                            <field name="server_type"/>
                            <button name="action_clear_smtp_values"
                                string="Reset Server"
                                type="object"
                                class="btn-secondary"
                                icon="fa-trash"
                                confirm="Are you sure you want to reset all values?" colspan="2"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="user_email_credentials_list_view" model="ir.ui.view">
       <field name="name">User Email Credentials List View</field>
       <field name="model">user.email.credentials</field>
       <field name="arch" type="xml">
           <list>
               <field name="user_id" string="User ID"/>
               <field name="user"/>
               <field name="password" password="True"/>
               <field name="server"/>
               <field name="port"/>
               <field name="is_ssl"/>
               <field name="server_type"/>
               <field name="user_smtp_status"
                   widget="badge"
                   readonly="1"
                   class="mr2"
                   decoration-success="user_smtp_status == 'connected'"
                   decoration-danger="user_smtp_status == 'disconnected'"/>
           </list>
       </field>
    </record>


    <record id="action_user_email_credentials" model="ir.actions.act_window">
       <field name="name">User Email Credentials</field>
       <field name="res_model">user.email.credentials</field>
       <field name="view_mode">list,form</field>
       <field name="help" type="html">
           <p class="o_view_nocontent_smiling_face">
               User Email Credentials
           </p>
       </field>
    </record>


</odoo>