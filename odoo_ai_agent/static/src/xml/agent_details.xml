<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoo_ai_agent.AgentDetailsDialog" owl="1">
        <Dialog title="'Agent Details'" size="'lg'">
            <t t-slot="default">
                <!-- Loading state -->
                <t t-if="state.loading">
                    <div class="text-center py-5">
                        <i class="fa fa-spinner fa-spin me-2"></i> Loading agent details...
                    </div>
                </t>

                <!-- Error state -->
                <t t-elif="state.error">
                    <div class="alert alert-danger my-3">
                        <strong>Error:</strong> Failed to load agent details.
                    </div>
                </t>

                <!-- Agent data -->
                <t t-else="">
                    <div class="p-3">
                        <t t-if="state.data.name">
                            <h3 class="mb-4">
                                <i class="fa fa-user me-2"></i> <t t-esc="state.data.name"/> History
                            </h3>

                            <t t-if="state.data.history and state.data.history.length > 0">
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover align-middle">
                                        <thead class="table-dark">
                                            <tr>
                                                <th scope="col">Date</th>
                                                <th scope="col">Cost</th>
                                                <th scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                           <t t-foreach="state.data.history" t-as="row" t-key="row_index">
                                                <tr>
                                                    <td><t t-esc="row.date || '—'"/></td>
                                                    <td><t t-esc="row.cost || 0"/></td>
                                                    <td class="text-end">
<!--                                                        <button-->
<!--                                                            type="button"-->
<!--                                                            class="btn btn-sm btn-primary"-->
<!--                                                            t-on-click="redirect_to_review(row.id)">-->
<!--                                                            Review-->
<!--                                                        </button>-->

                                                    <button
                                                        class="btn btn-primary"
                                                        t-on-click="() => this.viewReview(row.id)">
                                                        Review
                                                    </button>
                                                    </td>
                                                </tr>
                                            </t>

                                        </tbody>
                                    </table>
                                </div>
                            </t>

                            <!-- No history -->
                            <t t-else="">
                                <div class="alert alert-info">No history found for this agent.</div>
                            </t>

                        </t>

                        <!-- No agent data -->
                        <t t-else="">
                            <div class="alert alert-warning">No agent data available.</div>
                        </t>
                    </div>
                </t>
            </t>
        </Dialog>
    </t>
</templates>
