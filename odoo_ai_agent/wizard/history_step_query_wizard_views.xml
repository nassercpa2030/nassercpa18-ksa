<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="history_step_query_form_view" model="ir.ui.view">
        <field name="name">history.step.query.form</field>
        <field name="model">history.step.query.view.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="active_id" string="Agent Response Step" readonly="1" invisible="1"/>
                        <field name="title" string="Agent Response Step" readonly="1"/>
                    </group>
                </group>
                <group>
                    <field name="python_functions"/>
                </group>
                <footer>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_history_step_query_wizard" model="ir.actions.act_window">
        <field name="name">History Step Query</field>
        <field name="res_model">history.step.query.view.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


</odoo>