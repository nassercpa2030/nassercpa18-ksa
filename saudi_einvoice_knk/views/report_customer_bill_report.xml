<?xml version="1.0" encoding="utf-8"?>
<odoo>
     
    <!-- تعريف تقرير وربطه بنموذج فواتير العملاء -->
    <record id="action_report_ustomer_bill_report" model="ir.actions.report">
        <field name="name">فاتورة ضريبية</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">saudi_einvoice_knk.report_customer_bill_template</field>
        <field name="print_report_name">'فاتورة عميل.pdf'</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- قالب QWeb لتصميم شكل التقرير مع QR وبيانات العميل -->
    <template id="report_customer_bill_template">
        <t t-set="company" t-value="docs[0].company_id"/>
        <t t-call="web.external_layout_standard">
            <t t-call="web.html_container">
                <div class="page">
                    
                    <!-- Header: بيانات الشركة شمال وبيانات العميل يمين -->
                    <div style="display:flex; justify-content:space-between; margin-bottom:20px; font-size:10px; direction: rtl;">
                        <!-- شمال: بيانات الشركة + لوجو -->
                        <div style="text-align:left;">
                            <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % company.logo" 
                                 style="max-height:60px; max-width:150px; object-fit:contain; margin-bottom:5px;"/>
                            <p style="margin:0;">
                                <strong t-esc="company.name"/>
                                <br/> السجل التجاري: <span t-esc="company.company_registry or '-'"/>
                                <br/> الرقم الضريبي: <span t-esc="company.vat or '-'"/>
                                <br/> العنوان: <span t-esc="company.street or '-'"/>
                            </p>
                        </div>

                        <!-- يمين: بيانات العميل كاملة -->
                        <div style="text-align:right;">
                            <p>
                                <strong>فاتورة إلى:</strong>
                                <br/> الاسم: <span t-esc="docs[0].partner_id.name"/>
                                <br/> العنوان: <span t-esc="docs[0].partner_id.street or '-'"/>
                                <br/> السجل التجاري: <span t-esc="docs[0].partner_id.company_registry or '-'"/>
                                <br/> الرقم الضريبي (VAT): <span t-esc="docs[0].partner_id.vat or '-'"/>
                                <br/><strong>رقم الفاتورة:</strong> <span t-esc="docs[0].name"/>
                                <br/><strong>تاريخ الفاتورة:</strong> <span t-esc="docs[0].invoice_date"/>
                            </p>
                        </div>
                    </div>

                    <hr/>

                    <!-- جدول المكافآت والفواتير -->
                    <table class="table table-bordered" style="width: 100%; direction: rtl; font-size: 10px; border-collapse:collapse;">
                        <thead style="background-color: #f0f0f0;">
                            <tr>
                                <th style="padding: 8px; text-align: center;">رقم الفاتورة</th>
                                <th style="padding: 8px; text-align: center;">أسم العميل</th>
                                <th style="padding: 8px; text-align: center;">أمر البيع</th>
                                <th style="padding: 8px; text-align: center;">إسم المشروع</th>
                                <th style="padding: 8px; text-align: center;">قيمة العقد</th>
                                <th style="padding: 8px; text-align: center;">نسبة العمولة</th>
                                <th style="padding: 8px; text-align: center;">قيمة فاتورة المسوق</th>
                                <th style="padding: 8px; text-align: center;">المبلغ المستحق</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_sum" t-value="0.0"/> 
                            <t t-set="amount_residual_sig" t-value="0.0"/> 

                            <t t-foreach="docs" t-as="bill">
                                <tr>
                                    <td style="padding: 8px;"><span t-field="bill.name"/></td>
                                    <td style="padding: 8px;"><span t-field="bill.sale_order_id_finance.partner_id.name" /></td>
                                    <td style="padding: 8px;"><span t-field="bill.sale_order_id_finance.name" t-if="bill.sale_order_id_finance"/></td>
                                    <td style="padding: 7px; text-align: center;"><span t-field="bill.sale_order_id_finance.project_name" t-if="bill.sale_order_id_finance"/></td>
                                    <td style="padding: 10px; text-align: center;"><span t-field="bill.sale_order_id_finance.amount_untaxed" t-if="bill.sale_order_id_finance"/></td>
                                    <td style="padding: 7px; text-align: center;"><span t-field="bill.sale_order_id_finance.broker_percentage_" t-if="bill.sale_order_id_finance"/><b>%</b></td>
                                    <td style="padding: 8px; text-align: left;"><span t-field="bill.amount_total" t-options='{"widget": "monetary", "display_currency": bill.currency_id}'/></td>
                                    <td style="padding: 8px; text-align: left;"><span t-field="bill.amount_residual_signed" t-options='{"widget": "monetary", "display_currency": bill.currency_id}'/></td>

                                    <t t-set="total_sum" t-value="total_sum + (bill.amount_total or 0.0)"  />
                                    <t t-set="amount_residual_sig" t-value="amount_residual_sig + (bill.amount_residual_signed or 0.0)"  />
                                </tr>
                            </t>

                            <!-- صفوف المجموع النهائي -->
                            <tr style="font-weight:bold; border-top: 2px solid black;">
                                <td colspan="7" style="text-align:right; padding:8px;">إجمالي المبلغ المستحق:</td>
                                <td style="padding:8px; text-align:left;"><span t-esc="'{:,.2f}'.format(amount_residual_sig or 0.0)"/><b>SR</b></td>
                            </tr>
                            <tr style="font-weight:bold; border-top: 2px solid black;">
                                <td colspan="6" style="text-align:right; padding:8px;">إجمالي المبالغ:</td>
                                <td style="padding:8px; text-align:left;"><span t-esc="'{:,.2f}'.format(total_sum or 0.0)"/><b>SR</b></td>
                            </tr>
                        </tbody>
                    </table>

                    <hr/>

                    <!-- Summary + QR Code -->
                    <div style="display:flex; justify-content:space-between; margin-top:15px;">
                        <div style="font-size:10px;">
                            <p>المجموع غير شامل الضريبة: <span t-esc="docs[0].amount_untaxed"/> SAR</p>
                            <p>الضريبة (VAT 15%): <span t-esc="docs[0].amount_tax"/> SAR</p>
                            <p><strong>الإجمالي الكلي: <span t-esc="docs[0].amount_total"/> SAR</strong></p>
                        </div>
                        <div style="text-align:center;">
                            <!--img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=120&amp;height=120' % docs[0].l10n_sa_qr_code"/-->
                           <img t-if="doc.get_qr_code()" style="display:block;" t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s'%('QR', doc.get_qr_code(), 110, 110)"/>
                            <p style="font-size:10px;">Scan for ZATCA Invoice</p>
                        </div>
                    </div>

                    <hr/>

                    <!-- Footer: بيانات الاتصال بالشركة -->
                    <div style="margin-top:20px; font-size:9px; text-align:center; border-top:1px solid #ccc; padding-top:5px;">
                        <p>الهاتف: <span t-esc="company.phone or '-'"/> | البريد الإلكتروني: <span t-esc="company.email or '-'"/> | الموقع الإلكتروني: <span t-esc="company.website or '-'"/></p>
                        <p>هذه فاتورة ضريبية صادرة وفق متطلبات هيئة الزكاة والضريبة والجمارك (ZATCA)</p>
                    </div>

                    <!-- توقيع الإعداد والمراجعة والإعتماد -->
                    <div style="display: flex; justify-content: space-between; margin-bottom: 15px; direction: rtl;">
                        <div style="width: 33%; text-align: right;"><span style="text-decoration: underline;">إعداد</span></div>
                        <div style="width: 33%; text-align: center;"><span style="text-decoration: underline;">مراجعة</span></div>
                        <div style="width: 33%; text-align: left;"><span style="text-decoration: underline;">إعتماد</span></div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
