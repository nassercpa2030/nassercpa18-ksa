<odoo>

<record id="ai_config_view_form" model="ir.ui.view">
    <field name="name">ai.config.form</field>
    <field name="model">ai.config</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="api_key"/>
                    <field name="model"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="action_ai_config" model="ir.actions.act_window">
    <field name="name">AI Configuration</field>
    <field name="res_model">ai.config</field>
    <field name="view_mode">form</field>
</record>

<menuitem id="menu_ai_root" name="AI"/>

<menuitem id="menu_ai_config"
          name="Configuration"
          parent="menu_ai_root"
          action="action_ai_config"/>

</odoo>
