<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="order_verification" name="Verify Document">
        <t t-call="web.basic_layout">

            <div class="card text-center">
                <div class="card-header bg-transparent">
                                <img src="/kbi_custom/static/img/header.jpeg" class="w-100"/>

                </div>
                <div class="card-body">


                    <div class="card my-5">
                        <div class="card-header text-center alert-success" t-if="valid">
                            <h3>Verified Document</h3>
                            <h5 class="text-mute">with following information</h5>
                        </div>
                        <div class="card-header text-center alert-warning " t-if="valid and state not in ['sale','close']">
                            <h5>Draft Document valid until :
                                <span t-esc="doc_expiry"/>
                            </h5>
                        </div>

                        <div class="card-header text-center alert-danger " t-if="not valid">
                            <h3>Unverified Document</h3>
                        </div>
                        <div class="card-header text-center alert-warning " t-if="not valid">
                            <h5>Please contact us</h5>
                        </div>
                    </div>
                    <div style="" t-if="valid">
                        <div class="card">
                            <div class="card-body">
                                <div class="row border-bottom">
                                    <div class="col-2 text-start ">Document No.</div>
                                    <div class="col-8 text-center ">
                                        <span t-esc="doc_no"/>
                                    </div>
                                    <div class="col-2 text-end ">رقم المستند</div>
                                </div>
                                <div class="row border-bottom">
                                    <div class="col-2 text-start ">Document Status</div>
                                    <div class="col-8 text-center ">
                                        <span t-esc="'Draft' if doc_state in ['draft','send'] else 'Under Review' if doc_state in ['to approve'] else 'Confirmed'"/>
                                    </div>
                                    <div class="col-2 text-end ">حالة المستند</div>
                                </div>
                                <div class="row border-bottom">
                                    <div class="col-2 text-start ">Customer Name</div>
                                    <div class="col-8 text-center">
                                        <span t-esc="partner_id"/>
                                    </div>
                                    <div class="col-2 text-end ">اسم العميل</div>
                                </div>
                                <div class="row border-bottom">
                                    <div class="col-2 text-start ">Subject</div>
                                    <div class="col-8 text-center ">
                                        <span t-esc="subject"/>
                                    </div>
                                    <div class="col-2 text-end ">الموضوع</div>
                                </div>
                                <div class="row border-bottom">
                                    <div class="col-2 text-start ">Issue Date</div>
                                    <div class="col-8 text-center ">
                                        <span t-esc="date"/>
                                    </div>
                                    <div class="col-2 text-end ">تاريخ الإصدار</div>
                                </div>
                                <div class="row border-bottom">
                                    <div class="col-2 text-start ">Responsible</div>
                                    <div class="col-8 text-center ">
                                        <span t-esc="user_id"/>
                                    </div>
                                    <div class="col-2 text-end ">المسؤول</div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="card-footer bg-transparent">
                    <img src="/kbi_custom/static/img/footer.jpeg" class="w-100"/>
                </div>
            </div>






    </t>
</template>
        </odoo>