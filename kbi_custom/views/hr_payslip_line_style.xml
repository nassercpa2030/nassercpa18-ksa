            <!-- ⭐ Bold NAME -->
            <xpath expr="//field[@name='line_ids']/list/field[@name='name']" position="attributes">
                <attribute name="style">font-weight: bold; color: inherit;</attribute>
            </xpath>

        </field>
    </record>
</odoo>
