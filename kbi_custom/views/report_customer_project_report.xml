<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_project_tracking" model="ir.actions.report">
        <field name="name">نموذج تتبع أمر البيع</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_project_tracking</field>
        <field name="print_report_name">f"أمر بيع - {object.name or ''} - {object.partner_id.name or ''}"</field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="sale.order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_customer_project_tracking">
        <t t-foreach="docs" t-as="o">
            <t t-call="kbi_custom.external_layout_seti">

                <style>
                 @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');

                    body, table, td, th {
                        font-family: 'Tajawal', sans-serif;
                        font-size: 13px;
                    }

                    th {
                        font-weight: bold;
                        font-size: 13.5px;
                        background:#EAF3FF;
                    }

                    table {
                        width: 100%;
                        border-collapse: collapse;
                    }

                    td, th {
                        padding:5px;
                        border:1px solid #2F6FB2;
                        text-align:right;
                    }

                    .thank-you {
                        text-align:center;
                        font-size:12px;
                    }

                    .thank-you .decor {
                        color:#c71585;
                        margin-top:5px;
                        letter-spacing:2px;
                    }
                </style>

                <div class="page" style="margin:0;padding:0 0 180px 0;">

                    <!-- بيانات السيل أوردر -->
                    <table style="margin-top:12px;">
                        <tr>
                            <td width="100%">
                                <table width="100%" style="border-collapse:collapse;">
                                    <tr>
                                        <td width="33%" style="text-align:right;"><strong>رقم أمر البيع</strong></td>
                                        <td width="34%" style="text-align:center;"><span t-field="o.name"/></td>
                                        <td width="33%" style="text-align:left;"><strong>Sale Order No</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>العميل</strong></td>
                                        <td style="text-align:center;"><span t-field="o.partner_id"/></td>
                                        <td style="text-align:left;"><strong>Customer</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الإنشاء</strong></td>
                                        <td style="text-align:center;"><span t-field="o.create_date"/></td>
                                        <td style="text-align:left;"><strong>Created On</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>أنشئ بواسطة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.create_uid"/></td>
                                        <td style="text-align:left;"><strong>Created By</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الطلب</strong></td>
                                        <td style="text-align:center;"><span t-field="o.date_order"/></td>
                                        <td style="text-align:left;"><strong>Order Date</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>الخدمة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.project_name"/></td>
                                        <td style="text-align:left;"><strong>Service</strong></td>
                                    </tr>

                                    <!-- أول دفعة -->
                                    <tr t-set="first_payment" t-value="o.env['account.payment'].search([('sale_order_id','=',o.id)], order='payment_date asc', limit=1)"/>
                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الدفعة الأولى</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="first_payment"><span t-field="first_payment.payment_date"/> - <span t-field="first_payment.journal_id"/></t>
                                            <t t-else="">-</t>
                                        </td>
                                        <td style="text-align:left;"><strong>First Payment Date - Bank</strong></td>
                                    </tr>

                                    <!-- ثاني دفعة -->
                                    <tr t-set="second_payment" t-value="o.env['account.payment'].search([('sale_order_id','=',o.id)], order='payment_date asc', offset=1, limit=1)"/>
                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الدفعة الثانية</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="second_payment"><span t-field="second_payment.payment_date"/> - <span t-field="second_payment.journal_id"/></t>
                                            <t t-else="">-</t>
                                        </td>
                                        <td style="text-align:left;"><strong>Second Payment Date - Bank</strong></td>
                                    </tr>

                                    <!-- الفواتير المرتبطة -->
                                    <tr t-foreach="o.invoice_ids" t-as="inv">
                                        <td style="text-align:right;"><strong>رقم الفاتورة</strong></td>
                                        <td style="text-align:center;"><span t-field="inv.name"/> - <span t-field="inv.date"/></td>
                                        <td style="text-align:left;"><strong>Invoice No - Date</strong></td>
                                    </tr>

                                    <!-- مدير الجودة -->
                                    <tr>
                                        <td style="text-align:right;"><strong>مدير الجودة</strong></td>
                                        <td></td>
                                        <td style="text-align:left;"><strong>Quality Manager</strong></td>
                                    </tr>

                                    <!-- مدير المالية -->
                                    <tr>
                                        <td style="text-align:right;"><strong>مدير المالية</strong></td>
                                        <td></td>
                                        <td style="text-align:left;"><strong>Finance Manager</strong></td>
                                    </tr>

                                    <!-- قيد الإغلاق -->
                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ قيد الإغلاق ورقمه</strong></td>
                                        <td style="text-align:center;">
                                            <span t-field="o.final_close_entry_date"/> - <span t-field="o.final_close_entry"/>
                                        </td>
                                        <td style="text-align:left;"><strong>Closing Entry Date & No</strong></td>
                                    </tr>

                                    <!-- التوقيعات -->
                                    <tr>
                                        <td style="text-align:center;" colspan="3">
                                            <table style="width:100%; border:none; text-align:center;">
                                                <tr>
                                                    <td>..................................</td>
                                                    <td>..................................</td>
                                                </tr>
                                                <tr>
                                                    <td>توقيع مدير الجودة</td>
                                                    <td>توقيع مدير المالية</td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>

                                    <!-- الختم الرسمي -->
                                    <tr>
                                        <td style="text-align:center;" colspan="3">
                                            <strong>الختم الرسمي</strong>
                                        </td>
                                    </tr>

                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- شكر ودعم نهائي -->
                    <div class="thank-you" style="margin-top:40px; text-align:center; font-size:12px; line-height:1.4;">
                        <strong>نشكر لكم ثقتكم باستخدام نظام أودوو 🌸</strong>
                        <div class="decor" style="margin:5px 0;">❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀</div>
                        <p style="margin-top:5px; font-size:11px; font-style:italic;">
                            مقدم من إدارة الدعم الفني بشركة <strong>ناصر عوض أل كيرعان – محاسبون ومراجعون قانونيون</strong>، متمنين لكم دوام التميز والرقي.
                        </p>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
