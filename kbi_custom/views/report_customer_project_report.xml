<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_project_tracking" model="ir.actions.report">
        <field name="name">نموذج تتبع أمر البيع</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_project_tracking</field>
        <field name="print_report_name">
            f"أمر بيع - {object.name or ''} - {object.partner_id.name or ''}"
        </field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_customer_project_tracking">
        <t t-foreach="docs" t-as="o">
            <t t-call="kbi_custom.external_layout_seti">

                <style>
                    @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');
                    

                    body, table, td, th {
                        font-family: 'Tajawal', sans-serif;
                        font-size: 13px;
                        font-weight: bold;
                    }

                    table {
                        width: 100%;
                        border-collapse: collapse;
                    }

                    td, th {
                        padding: 6px;
                        border: 1px solid #2F6FB2;
                        text-align: right;
                        vertical-align: middle;
                    }

                    .header-title {
                        font-size: 18px;
                        text-align: center;
                        margin-bottom: 12px;
                    }

                    .thank-you {
                        text-align: center;
                        font-size: 12px;
                        margin-top: 40px;
                        color: #2F6FB2;
                    }
                </style>

                <div class="page">

                    <div class="header-title">تقرير متابعة أمر البيع</div>

                    <table>
                        <tr>
                            <td><strong>تاريخ الطباعة</strong></td>
                            <td style="text-align:center;">
                                <span t-esc="o.printing_date or ''"/>
                            </td>
                            <td style="text-align:center;">Printing Date</td>
                        </tr>

                        <tr>
                            <td>رقم أمر البيع</td>
                            <td style="text-align:center;">
                                <span t-esc="o.name or ''"/>
                            </td>
                            <td style="text-align:center;">Sale Order No</td>
                        </tr>

                        <tr>
                            <td>العميل</td>
                            <td style="text-align:center;">
                                <span t-esc="o.partner_id.name or ''"/>
                            </td>
                            <td style="text-align:center;">Customer</td>
                        </tr>

                        <tr>
                            <td>تاريخ الطلب</td>
                            <td style="text-align:center;">
                                <span t-esc="o.date_order or ''"/>
                            </td>
                            <td style="text-align:center;">Order Date</td>
                        </tr>

                        <tr>
                            <td>الخدمة المقدمة</td>
                            <td style="text-align:center;">
                                <span t-esc="o.project_name or ''"/>
                            </td>
                            <td style="text-align:center;">Provided Service</td>
                        </tr>

                        <!-- ===================== الدفعات ===================== -->
                        <t t-set="payments"
                           t-value="o.env['account.payment'].search([
                                ('partner_id','=',o.partner_id.id),
                                ('state','=','posted')
                           ], order='date asc') or []"/>

                        <t t-set="payment_count" t-value="len(payments)"/>
                        <t t-set="idx" t-value="0"/>

                        <t t-if="payment_count &gt; 0">
                            <t t-foreach="payments" t-as="pay">
                                <t t-set="idx" t-value="idx + 1"/>

                                <tr>
                                    <td style="text-align:center;">
                                        الدفعة <t t-esc="idx"/>
                                    </td>

                                    <td style="text-align:center;">
                                        <span t-esc="pay.amount or 0"/> ريال<br/>
                                        <span t-esc="pay.journal_id.name or '-'"/><br/>
                                        تاريخ الدفع:
                                        <span t-esc="pay.date or '-'"/>
                                    </td>

                                    <td style="text-align:center;">
                                        Payment <t t-esc="idx"/><br/>Bank
                                    </td>
                                </tr>

                            </t>
                        </t>

                        <t t-if="payment_count == 0">
                            <tr>
                                <td style="text-align:center;">الدفعات</td>
                                <td style="text-align:center;">لا توجد دفعات</td>
                                <td style="text-align:center;">Payments</td>
                            </tr>
                        </t>

                        <!-- ===================== الإجماليات ===================== -->
                        <tr>
                            <td>إجمالي قبل الضريبة</td>
                            <td style="text-align:center;">
                                <span t-esc="o.amount_untaxed or 0"/> ريال
                            </td>
                            <td style="text-align:center;">Before Tax</td>
                        </tr>

                        <tr>
                            <td>الضريبة</td>
                            <td style="text-align:center;">
                                <span t-esc="o.amount_tax or 0"/> ريال
                            </td>
                            <td style="text-align:center;">Tax</td>
                        </tr>

                        <tr>
                            <td>الإجمالي بعد الضريبة</td>
                            <td style="text-align:center;">
                                <span t-esc="o.amount_total or 0"/> ريال
                            </td>
                            <td style="text-align:center;">After Tax</td>
                        </tr>

                        <tr>
                            <td>عدد الدفعات</td>
                            <td style="text-align:center;">
                                <span t-esc="payment_count"/>
                            </td>
                            <td style="text-align:center;">Number of Payments</td>
                        </tr>

                        <!-- ===================== التوقيعات ===================== -->
                        <tr>
                            <td style="text-align:center;">توقيع مدير الجودة</td>
                            <td style="text-align:center;">توقيع مدير المجموعة</td>
                            <td style="text-align:center;">توقيع مدير المالية</td>
                        </tr>

                        <tr style="height:60px;">
                            <td style="text-align:center;">..................................</td>
                            <td style="text-align:center;">..................................</td>
                            <td style="text-align:center;">..................................</td>
                        </tr>

                    </table>

                    <div class="thank-you">
                        🌸🌸🌸 نشكر لكم ثقتكم باستخدام نظام أودوو 🌸🌸🌸
                        <br/>
                        مقدم من إدارة الدعم الفني
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>

                   
