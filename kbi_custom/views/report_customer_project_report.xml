                                           ..............................
                                       </td>
                                       
                                        <td  class="signature-images" style="text-align:center; padding:10px; height:55px; vertical-align:bottom; ">
                                             <!-- <t t-set="archive_user" t-value="o.env['res.users'].browse(563)"/> -->
                                           <img t-if="o.archive_signiture or o.archive_signiture_exception"      t-att-src="image_data_uri(o.env['res.users'].browse(563).sign_signature)" style="max-height:80px; max-width:180px;"/>
                                       </td>
                                        <td  class="signature-images" style="text-align:center; padding:10px; height:55px; vertical-align:bottom; ">
                                           <img t-if="o.finance_assign" t-att-src="image_data_uri(o.finance_assign)" style="max-height:80px; max-width:180px;"/>
                                       </td>

