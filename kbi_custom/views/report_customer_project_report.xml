<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_project_tracking" model="ir.actions.report">
        <field name="name">نموذج تتبع أمر البيع</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_project_tracking</field>
        <field name="print_report_name">
            'أمر بيع - %s' % (object.name or '')
        </field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="sale.order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB TEMPLATE -->
    <!-- ============================= -->
    <template id="report_customer_project_tracking">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">

                <style>
                    body, table, td, th {
                        font-family: 'Tajawal', sans-serif;
                        font-size: 13px;
                    }
                    table {
                        width: 100%;
                        border-collapse: collapse;
                    }
                    th, td {
                        padding: 6px;
                        text-align: right;
                    }
                </style>

                <div class="page">

                    <!-- ================= Header ================= -->
                    <table>
                        <tr>
                            <td colspan="2" style="text-align:center; font-size:16px; font-weight:bold;">
                                نموذج تتبع أمر البيع
                            </td>
                        </tr>
                    </table>

                    <!-- ================= Sale Order Info ================= -->
                    <table style="margin-top:15px;">
                        <tr>
                            <td><strong>رقم أمر البيع</strong></td>
                            <td><span t-field="o.name"/></td>
                            <td><strong>العميل</strong></td>
                            <td><span t-field="o.partner_id"/></td>
                        </tr>
                        <tr>
                            <td><strong>تاريخ الإنشاء</strong></td>
                            <td><span t-field="o.create_date"/></td>
                            <td><strong>أُنشئ بواسطة</strong></td>
                            <td><span t-field="o.create_uid"/></td>
                        </tr>
                        <tr>
                            <td><strong>تاريخ الطلب</strong></td>
                            <td><span t-field="o.date_order"/></td>
                            <td><strong>الخدمة</strong></td>
                            <td><span t-esc="o.project_name or ''"/></td>
                        </tr>
                    </table>

                    <!-- ================= Payments Tracking ================= -->
                    <table style="margin-top:20px;">
                        <tr>
                            <td colspan="4" style="font-weight:bold;">الدفعات</td>
                        </tr>
                        <tr>
                            <td><strong>تاريخ الدفعة الأولى</strong></td>
                            <td><span t-esc="o.first_payment_date or ''"/></td>
                            <td><strong>البنك المستلم</strong></td>
                            <td><span t-esc="o.first_payment_bank or ''"/></td>
                        </tr>
                        <tr>
                            <td><strong>تاريخ الدفعة الثانية</strong></td>
                            <td><span t-esc="o.second_payment_date or ''"/></td>
                            <td><strong>البنك المستلم</strong></td>
                            <td><span t-esc="o.second_payment_bank or ''"/></td>
                        </tr>
                    </table>

                    <!-- ================= Invoices ================= -->
                    <table style="margin-top:20px;">
                        <tr>
                            <td colspan="4" style="font-weight:bold;">الفواتير المرتبطة</td>
                        </tr>
                        <t t-foreach="o.invoice_ids" t-as="inv">
                            <tr>
                                <td colspan="2">
                                    رقم الفاتورة:
                                    <strong><span t-esc="inv.name"/></strong>
                                </td>
                                <td colspan="2">
                                    تاريخها:
                                    <span t-field="inv.invoice_date"/>
                                </td>
                            </tr>
                        </t>
                    </table>

                    <!-- ================= Approvals ================= -->
                    <table style="width:100%; margin-top:35px; border-collapse:collapse;">
                        <!-- Titles -->
                        <tr>
                            <td style="width:50%; text-align:center; font-weight:bold;">
                                مدير الجودة
                            </td>
                            <td style="width:50%; text-align:center; font-weight:bold;">
                                مدير المالية
                            </td>
                        </tr>

                        <!-- Names -->
                        <tr>
                            <td style="text-align:center;">
                                <span t-esc="o.quality_manager_id.name or ''"/>
                            </td>
                            <td style="text-align:center;">
                                <span t-esc="o.finance_manager_id.name or ''"/>
                            </td>
                        </tr>

                        <!-- Signatures -->
                        <tr>
                            <td style="text-align:center; padding-top:15px;">
                                <t t-if="o.quality_manager_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % o.quality_manager_signature"
                                         style="height:70px;"/>
                                </t>
                            </td>
                            <td style="text-align:center; padding-top:15px;">
                                <t t-if="o.finance_manager_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % o.finance_manager_signature"
                                         style="height:70px;"/>
                                </t>
                            </td>
                        </tr>

                        <!-- Dates -->
                        <tr>
                            <td style="text-align:center; font-size:12px;">
                                التاريخ:
                                <span t-esc="o.quality_approve_date or ''"/>
                            </td>
                            <td style="text-align:center; font-size:12px;">
                                التاريخ:
                                <span t-esc="o.finance_approve_date or ''"/>
                            </td>
                        </tr>
                    </table>

                    <!-- ================= Closing Entry ================= -->
                    <table style="margin-top:25px;">
                        <tr>
                            <td><strong>تاريخ قيد الإغلاق</strong></td>
                            <td><span t-esc="o.final_close_entry_date or ''"/></td>
                            <td><strong>رقم القيد</strong></td>
                            <td><span t-esc="o.final_close_entry or ''"/></td>
                        </tr>
                    </table>

                    <!-- ================= Official Stamp ================= -->
                    <div style="margin-top:30px; text-align:center;">
                        <t t-if="o.company_id.stamp_image">
                            <img t-att-src="'data:image/png;base64,%s' % o.company_id.stamp_image"
                                 style="height:90px;"/>
                        </t>
                        <div style="font-size:12px; margin-top:5px;">
                            الختم الرسمي
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
