<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_project_tracking" model="ir.actions.report">
        <field name="name">نموذج تتبع أمر البيع</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_project_tracking</field>
        <field name="print_report_name">f"أمر بيع - {object.name or ''} - {object.partner_id.name or ''}"</field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_customer_project_tracking">
        <t t-foreach="docs" t-as="o">
            <t t-call="kbi_custom.external_layout_seti">

                <style>
                   @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');

                    body, table, td, th {
                        font-family: 'Tajawal', sans-serif;
                        font-size: 13px;
                    }

                    h1 {
                        font-size: 18px;
                        text-align:center;
                        margin-bottom:15px;
                    }

                    th {
                        font-weight: bold;
                        font-size: 13.5px;
                        background:#EAF3FF;
                    }

                    table {
                        width: 100%;
                        border-collapse: collapse;
                    }

                    td, th {
                        padding:5px;
                        border:1px solid #2F6FB2;
                        text-align:right;
                    }

                    .thank-you {
                        text-align:center;
                        font-size:12px;
                        color:#5a2f84;
                    }

                    .thank-you .decor {
                        color:#c71585;
                        margin-top:5px;
                        letter-spacing:2px;
                    }

                </style>

                <div class="page" style="margin:0;padding:0 0 180px 0;">

                    <!-- عنوان التقرير -->
                    <h1>تقرير متابعة أمر البيع</h1>

                    <!-- بيانات السيل أوردر -->
                    <table style="margin-top:12px;">
                        <tr>
                            <td width="100%">
                                <table width="100%" style="border-collapse:collapse;">
                                    <tr>
                                        <td width="33%" style="text-align:right;"><strong>رقم أمر البيع</strong></td>
                                        <td width="34%" style="text-align:center;"><span t-field="o.name"/></td>
                                        <td width="33%" style="text-align:left;"><strong>Sale Order No</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>العميل</strong></td>
                                        <td style="text-align:center;"><span t-field="o.partner_id"/></td>
                                        <td style="text-align:left;"><strong>Customer</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الإنشاء</strong></td>
                                        <td style="text-align:center;"><span t-field="o.create_date"/></td>
                                        <td style="text-align:left;"><strong>Created On</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>أنشئ بواسطة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.create_uid"/></td>
                                        <td style="text-align:left;"><strong>Created By</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الطلب</strong></td>
                                        <td style="text-align:center;"><span t-field="o.date_order"/></td>
                                        <td style="text-align:left;"><strong>Order Date</strong></td>
                                    </tr>

                                    <tr>
                                        <td style="text-align:right;"><strong>الخدمة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.project_name"/></td>
                                        <td style="text-align:left;"><strong>Service</strong></td>
                                    </tr>

                                    <!-- الدفعات -->
                                    <tr t-set="payments" t-value="o.env['account.payment'].search([('sale_order_id','=',o.id)], order='date asc')"/>
                                    <tr t-set="payment_count" t-value="len(payments)"/>

                                    <!-- دفعة أولى -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الدفعة الأولى</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="payment_count &gt;= 1">
                                                <span t-esc="payments[0].amount"/> ريال<br/>
                                                <span t-esc="payments[0].journal_id.name"/>
                                            </t>
                                            <t t-else="">لا يوجد دفعة أولى</t>
                                        </td>
                                        <td style="text-align:left;"><strong>First Payment - Bank</strong></td>
                                    </tr>

                                    <!-- دفعة ثانية -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الدفعة الثانية</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="payment_count &gt;= 2">
                                                <span t-esc="payments[1].amount"/> ريال<br/>
                                                <span t-esc="payments[1].journal_id.name"/>
                                            </t>
                                            <t t-else="">لا يوجد دفعة ثانية</t>
                                        </td>
                                        <td style="text-align:left;"><strong>Second Payment - Bank</strong></td>
                                    </tr>

                                    <!-- دفعة ثالثة -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الدفعة الثالثة</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="payment_count &gt;= 3">
                                                <span t-esc="payments[2].amount"/> ريال<br/>
                                                <span t-esc="payments[2].journal_id.name"/>
                                            </t>
                                            <t t-else="">لا يوجد دفعة ثالثة</t>
                                        </td>
                                        <td style="text-align:left;"><strong>Third Payment - Bank</strong></td>
                                    </tr>

                                    <!-- الفواتير -->
                                    <tr t-set="invoice_count" t-value="len(o.invoice_ids)"/>
                                    <tr t-foreach="o.invoice_ids" t-as="inv" t-index="i">
                                        <td style="text-align:right;"><strong>الفاتورة <t t-esc="i+1"/></strong></td>
                                        <td style="text-align:center;">
                                            <span t-field="inv.name"/> - <span t-field="inv.date"/>
                                        </td>
                                        <td style="text-align:left;"><strong>Invoice <t t-esc="i+1"/> - Date</strong></td>
                                    </tr>
                                    <tr t-if="invoice_count == 0">
                                        <td style="text-align:right;"><strong>الفاتورة الأولى</strong></td>
                                        <td style="text-align:center;">لا توجد فاتورة</td>
                                        <td style="text-align:left;"><strong>First Invoice - Date</strong></td>
                                    </tr>

                                    <!-- إجمالي وأقساط -->
                                    <tr>
                                        <td style="text-align:right;"><strong>إجمالي أمر البيع قبل الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-esc="o.amount_untaxed"/> ريال</td>
                                        <td style="text-align:left;"><strong>Total Before Tax</strong></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;"><strong>الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-esc="o.amount_tax"/> ريال</td>
                                        <td style="text-align:left;"><strong>Tax</strong></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;"><strong>إجمالي بعد الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-esc="o.amount_total"/> ريال</td>
                                        <td style="text-align:left;"><strong>Total After Tax</strong></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;"><strong>الباقي</strong></td>
                                        <td style="text-align:center;"><span t-esc="o.amount_total - sum(p.amount for p in payments)"/> ريال</td>
                                        <td style="text-align:left;"><strong>Remaining</strong></td>
                                    </tr>

                                    <!-- التوقيعات والختم -->
                                    <tr>
                                        <td style="text-align:center;" colspan="3">
                                            <table style="width:100%; border:none; text-align:center;">
                                                <tr>
                                                    <td style="height:50px; font-size:18px;">....................................................</td>
                                                    <td style="height:50px; font-size:18px;">....................................................</td>
                                                </tr>
                                                <tr>
                                                    <td><strong>توقيع المدير</strong></td>
                                                    <td><strong>توقيع مدير المجموعة</strong></td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2" style="text-align:center; height:25px;">
                                                        التاريخ: <t t-esc="fields.Date.today().strftime('%d/%m/%Y')"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2" style="text-align:center; height:60px; font-size:16px;">
                                                        <strong>الختم الرسمي</strong>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>

                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- شكر ودعم نهائي -->
                    <div class="thank-you" style="margin-top:40px; text-align:center; font-size:12px; line-height:1.4;">
                        <strong>نشكر لكم ثقتكم باستخدام نظام أودوو 🌸</strong>
                        <div class="decor" style="margin:5px 0;">❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀</div>
                        <p style="margin-top:5px; font-size:11px; font-style:italic;">
                            مقدم من إدارة الدعم الفني بشركة <strong>ناصر عوض أل كيرعان – محاسبون ومراجعون قانونيون</strong>، متمنين لكم دوام التميز والرقي.
                        </p>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>


                      
