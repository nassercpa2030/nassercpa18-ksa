<!-- الدفعات -->
<t t-set="payments"
   t-value="o.env['account.payment'].search([('sale_order_id','=',o.id)], order='date asc') or []"/>

<t t-if="payments">
    <t t-set="pay_index" t-value="0"/>
    <t t-set="payment_count" t-value="len(payments)"/>
    
    <!-- تعريف قائمة ألوان -->
   <!--t t-set="bg_colors" t-value="['#cce5ff', '#99ccff', '#66b2ff', '#3399ff', '#99aab5', '#cccccc']"/-->
    <t t-set="bg_colors" t-value="['#e6f2ff', '#cce6ff', '#b3d9ff', '#99ccff', '#cce0e6', '#e6e6e6']"/>


    <t t-foreach="payments" t-as="pay">
        <t t-set="pay_index" t-value="pay_index + 1"/>
        
        <!-- حساب اللون حسب index -->
        <t t-set="color" t-value="bg_colors[(pay_index-1) % len(bg_colors)]"/>
        
        <tr t-att-style="'background-color: %s;' % color">
            <td>
                <strong>
                    الدفعة <t t-esc="pay_index"/><br/>
                    البنك/الخزنة
                </strong>
            </td>
            
    <!-- نسبة الدفع -->
           
            <td style="text-align:center;">
    <div>
        <strong>
            <span t-esc="round((pay.amount / o.amount_total * 100) if o.amount_total else 0, 2)"/> %
        </strong>
    </div>
    <div><strong><span t-esc="pay.journal_id.name or '-'"/></strong></div>
    <div>
        <small>
            تاريخ الدفع: <span t-esc="pay.date or '-'"/>
        </small>
    </div>
</td>


            <!--td style="text-align:center;">
                <div><strong><span t-esc="pay.amount or 0"/> ريال</strong></div>
                <div><strong><span t-esc="pay.journal_id.name or '-'"/></strong></div>
                <div>
                    <small>
                        تاريخ الدفع:
                       <strong> <span t-esc="pay.date or '-'"/></strong>
                    </small>
                </div>
            </td-->

            <td style="text-align:left;">
                <strong>
                    Payment <t t-esc="pay_index"/><br/>
                    Bank
                </strong>
            </td>
        </tr>
    </t>
</t>

<t t-if="not payments">
    <tr>
        <td><strong>الدفعات</strong></td>
        <td style="text-align:center;">0</td>
        <td style="text-align:left;"><strong>Payments</strong></td>
    </tr>
</t>


                                    
                                    <!-- الفواتير -->
<t t-set="invoices" t-value="o.invoice_ids or []"/>

<t t-if="invoices">
    <t t-set="inv_index" t-value="0"/>

    <t t-foreach="invoices" t-as="inv">
        <t t-set="inv_index" t-value="inv_index + 1"/>

        <tr>
            <td>
                <strong>فاتورة <t t-esc="inv_index"/></strong>
            </td>

            <td style="text-align:center;">
                <strong><span t-esc="inv.name or '-'"/> -
                <span t-esc="inv.date or '-'"/></strong>
            </td>

            <td style="text-align:left;">
                <strong>Invoice <t t-esc="inv_index"/> - Date</strong>
            </td>
        </tr>
    </t>
</t>

<t t-if="not invoices">
    <tr>
        <td><strong>فاتورة 1</strong></td>
        <td style="text-align:center;">-</td>
        <td style="text-align:left;"><strong>Invoice 1 - Date</strong></td>
    </tr>
</t>


                                    <!-- الإجمالي -->
