<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_project_tracking" model="ir.actions.report">
        <field name="name">نموذج تتبع أمر البيع</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_project_tracking</field>
        <field name="print_report_name">
            f"أمر بيع - {object.name or ''} - {object.partner_id.name or ''}"
        </field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_customer_project_tracking">
        <t t-foreach="docs" t-as="o">
            <t t-call="kbi_custom.external_layout_seti">

                <style>
                     @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');
                    body, table, td, th { font-family: 'Tajawal', sans-serif; font-size: 13px; }
                    table { width:100%; border-collapse:collapse; }
                    td, th { border:1px solid #2F6FB2; padding:6px; text-align:center; vertical-align:middle; }
                    th { background:#EAF3FF; font-weight:bold; }
                    .header-title { font-size:18px; font-weight:bold; text-align:center; margin-bottom:12px; }
                    .thank-you { text-align:center; font-size:12px; color:#2F6FB2; }
                </style>

                <div class="page">

                    <div class="header-title">تقرير متابعة أمر البيع</div>

                    <table>
                        <tr>
                            <td><strong>تاريخ الطباعة</strong></td>
                            <td><strong><span t-field="o.printing_date"/></strong></td>
                            <td><strong>Printing Date</strong></td>
                        </tr>

                        <tr>
                            <td><strong>رقم أمر البيع</strong></td>
                            <td><strong><span t-field="o.name"/></strong></td>
                            <td><strong>Sale Order No</strong></td>
                        </tr>

                        <tr>
                            <td><strong>العميل</strong></td>
                            <td><strong><span t-field="o.partner_id"/></strong></td>
                            <td><strong>Customer</strong></td>
                        </tr>

                        <tr>
                            <td><strong>تاريخ الطلب</strong></td>
                            <td><strong><span t-field="o.date_order"/></strong></td>
                            <td><strong>Order Date</strong></td>
                        </tr>

                        <tr>
                            <td><strong>الخدمة المقدمة</strong></td>
                            <td><strong><span t-field="o.project_name"/></strong></td>
                            <td><strong>Provided Service</strong></td>
                        </tr>

                        <!-- ================= الدفعات ================= -->
                        <t t-set="payments"
                           t-value="o.env['account.payment'].search([
                               ('sale_order_id','=',o.id),
                               ('state','=','posted')
                           ], order='date asc')"/>

                        <t t-set="pay_idx" t-value="0"/>

                        <t t-if="payments">
                            <t t-foreach="payments" t-as="pay">
                                <t t-set="pay_idx" t-value="pay_idx + 1"/>
                                <tr>
                                    <td><strong>الدفعة <t t-esc="pay_idx"/></strong></td>
                                    <td>
                                        <strong>
                                            <span t-esc="pay.amount"/> ريال<br/>
                                            <span t-esc="pay.journal_id.name"/><br/>
                                            تاريخ الدفع: <span t-esc="pay.date"/>
                                        </strong>
                                    </td>
                                    <td><strong>Payment <t t-esc="pay_idx"/><br/>Bank</strong></td>
                                </tr>
                            </t>
                        </t>

                        <t t-if="not payments">
                            <tr>
                                <td><strong>الدفعات</strong></td>
                                <td><strong>0</strong></td>
                                <td><strong>Payments</strong></td>
                            </tr>
                        </t>

                        <!-- ================= الفواتير ================= -->
                        <t t-set="inv_idx" t-value="0"/>

                        <t t-if="o.invoice_ids">
                            <t t-foreach="o.invoice_ids" t-as="inv">
                                <t t-set="inv_idx" t-value="inv_idx + 1"/>
                                <tr>
                                    <td><strong>الفاتورة <t t-esc="inv_idx"/></strong></td>
                                    <td><strong><span t-esc="inv.name"/> - <span t-esc="inv.date"/></strong></td>
                                    <td><strong>Invoice <t t-esc="inv_idx"/></strong></td>
                                </tr>
                            </t>
                        </t>

                        <t t-if="not o.invoice_ids">
                            <tr>
                                <td><strong>الفواتير</strong></td>
                                <td><strong>0</strong></td>
                                <td><strong>Invoices</strong></td>
                            </tr>
                        </t>

                        <!-- ================= الإجماليات ================= -->
                        <tr>
                            <td><strong>الإجمالي قبل الضريبة</strong></td>
                            <td><strong><span t-esc="o.amount_untaxed"/> ريال</strong></td>
                            <td><strong>Before Tax</strong></td>
                        </tr>

                        <tr>
                            <td><strong>الضريبة</strong></td>
                            <td><strong><span t-esc="o.amount_tax"/> ريال</strong></td>
                            <td><strong>Tax</strong></td>
                        </tr>

                        <tr>
                            <td><strong>الإجمالي بعد الضريبة</strong></td>
                            <td><strong><span t-esc="o.amount_total"/> ريال</strong></td>
                            <td><strong>Total</strong></td>
                        </tr>

                        <!-- ================= التوقيعات ================= -->
                        <tr>
                            <td><strong> توقيع مدير الجودة</strong></td>
                            <td><strong> توقيع مدير المجموعة</strong></td>
                            <td><strong> توقيع مدير المالية</strong></td>
                        </tr>
                        <tr>
                            <td>..............................</td>
                            <td>..............................</td>
                            <td>..............................</td>
                        </tr>
                    </table>

                    <!-- الشكر -->
                    <div class="thank-you" style="margin-top:40px;">
                        <strong>🌸🌸🌸 نشكر لكم ثقتكم باستخدام نظام أودوو 🌸🌸🌸</strong>
                        <p style="font-size:11px;">
                            مقدم من إدارة الدعم الفني بشركة
                            <strong>ناصر عوض أل كيرعان – محاسبون ومراجعون قانونيون</strong>
                        </p>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
                 
