<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_project_tracking" model="ir.actions.report">
        <field name="name">نموذج تتبع أمر البيع</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_project_tracking</field>
        <field name="print_report_name">f"أمر بيع - {object.name or ''} - {object.partner_id.name or ''}"</field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_customer_project_tracking">
        <t t-foreach="docs" t-as="o">
            <t t-call="kbi_custom.external_layout_seti">

                <style>
                       @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');

                    body, table, td, th {
                        font-family: 'Tajawal', sans-serif;
                        font-size: 13px;
                    }

                    th {
                        font-weight: bold;
                        font-size: 13.5px;
                        background:#EAF3FF;
                    }

                    table {
                        width: 100%;
                        border-collapse: collapse;
                    }

                    td, th {
                        padding:5px;
                        border:1px solid #2F6FB2;
                        text-align:right;
                    }

                    .thank-you {
                        text-align:center;
                        font-size:12px;
                        line-height:1.6;
                        background:#f9f9f9;
                        padding:10px;
                        border-radius:8px;
                    }

                    .thank-you .decor {
                        color:#d81b60;
                        margin-top:5px;
                        letter-spacing:3px;
                        font-size:16px;
                    }

                </style>

                <div class="page" style="margin:0;padding:0 0 180px 0;">

                    <!-- بيانات السيل أوردر -->
                    <table style="margin-top:12px;">
                        <tr>
                            <td width="100%">
                                <table width="100%" style="border-collapse:collapse;">

                                    <!-- رقم أمر البيع -->
                                    <tr>
                                        <td width="33%" style="text-align:right;"><strong>رقم أمر البيع</strong></td>
                                        <td width="34%" style="text-align:center;"><span t-field="o.name"/></td>
                                        <td width="33%" style="text-align:left;"><strong>Sale Order No</strong></td>
                                    </tr>

                                    <!-- العميل -->
                                    <tr>
                                        <td style="text-align:right;"><strong>العميل</strong></td>
                                        <td style="text-align:center;"><span t-field="o.partner_id"/></td>
                                        <td style="text-align:left;"><strong>Customer</strong></td>
                                    </tr>

                                    <!-- تاريخ الإنشاء -->
                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الإنشاء</strong></td>
                                        <td style="text-align:center;"><span t-field="o.create_date"/></td>
                                        <td style="text-align:left;"><strong>Created On</strong></td>
                                    </tr>

                                    <!-- أنشئ بواسطة -->
                                    <tr>
                                        <td style="text-align:right;"><strong>أنشئ بواسطة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.create_uid"/></td>
                                        <td style="text-align:left;"><strong>Created By</strong></td>
                                    </tr>

                                    <!-- تاريخ الطلب -->
                                    <tr>
                                        <td style="text-align:right;"><strong>تاريخ الطلب</strong></td>
                                        <td style="text-align:center;"><span t-field="o.date_order"/></td>
                                        <td style="text-align:left;"><strong>Order Date</strong></td>
                                    </tr>

                                    <!-- الخدمة -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الخدمة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.project_name"/></td>
                                        <td style="text-align:left;"><strong>Service</strong></td>
                                    </tr>

                                    <!-- الدفعات -->
                                    <tr t-set="payments" t-value="o.env['account.payment'].search([('sale_order_id','=',o.id)], order='date asc')"/>
                                    <tr t-set="payment_count" t-value="len(payments)"/>

                                    <!-- أول دفعة -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الدفعة الأولى</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="payment_count &gt;= 1">
                                                <span t-field="payments[0].amount"/> <br/>
                                                <span t-field="payments[0].journal_id"/>
                                            </t>
                                            <t t-else="">لا يوجد دفع أول</t>
                                        </td>
                                        <td style="text-align:left;"><strong>First Payment - Bank</strong></td>
                                    </tr>

                                    <!-- ثاني دفعة -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الدفعة الثانية</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="payment_count &gt;= 2">
                                                <span t-field="payments[1].amount"/> <br/>
                                                <span t-field="payments[1].journal_id"/>
                                            </t>
                                            <t t-else="">لا يوجد دفع ثاني</t>
                                        </td>
                                        <td style="text-align:left;"><strong>Second Payment - Bank</strong></td>
                                    </tr>

                                    <!-- ثالث دفعة -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الدفعة الثالثة</strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="payment_count &gt;= 3">
                                                <span t-field="payments[2].amount"/> <br/>
                                                <span t-field="payments[2].journal_id"/>
                                            </t>
                                            <t t-else="">لا يوجد دفع ثالث</t>
                                        </td>
                                        <td style="text-align:left;"><strong>Third Payment - Bank</strong></td>
                                    </tr>

                                    <!-- الفواتير المرتبطة -->
                                    <tr t-set="invoices" t-value="o.invoice_ids"/>
                                    <tr t-set="inv_count" t-value="len(invoices)"/>
                                    <tr t-foreach="range(3)" t-as="i">
                                        <td style="text-align:right;"><strong>فاتورة <t t-esc="['أولى','ثانية','ثالثة'][i]"/></strong></td>
                                        <td style="text-align:center;">
                                            <t t-if="i &lt; inv_count">
                                                <span t-field="invoices[i].name"/> <br/>
                                                <span t-field="invoices[i].date"/>
                                            </t>
                                            <t t-else="">لا يوجد فاتورة <t t-esc="['أولى','ثانية','ثالثة'][i]"/></t>
                                        </td>
                                        <td style="text-align:left;"><strong>Invoice <t t-esc="['First','Second','Third'][i]"/> - Date</strong></td>
                                    </tr>

                                    <!-- إجمالي السيل أوردر -->
                                    <tr>
                                        <td style="text-align:right;"><strong>الإجمالي قبل الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.amount_untaxed"/></td>
                                        <td style="text-align:left;"><strong>Subtotal</strong></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;"><strong>الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.amount_tax"/></td>
                                        <td style="text-align:left;"><strong>Tax</strong></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:right;"><strong>الإجمالي بعد الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-field="o.amount_total"/></td>
                                        <td style="text-align:left;"><strong>Total</strong></td>
                                    </tr>

                                    <!-- التوقيعات -->
                                    <tr>
                                        <td colspan="3" style="text-align:center; padding-top:20px;">
                                            <table style="width:100%; border:none; text-align:center;">
                                                <tr>
                                                    <td style="width:40%;">........................................</td>
                                                    <td style="width:40%;">........................................</td>
                                                </tr>
                                                <tr>
                                                    <td>توقيع المدير</td>
                                                    <td>توقيع مدير المجموعة</td>
                                                </tr>
                                                <tr>
                                                    <td colspan="2" style="text-align:center;"><span t-esc="(Date.today()).strftime('%d/%m/%Y')"/></td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>

                                    <!-- الختم الرسمي -->
                                    <tr>
                                        <td colspan="3" style="text-align:center; padding:15px 0; font-weight:bold;">الختم الرسمي</td>
                                    </tr>

                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- شكر ودعم نهائي -->
                    <div class="thank-you">
                        <strong style="color:#4a148c; font-size:13px;">نشكر لكم ثقتكم باستخدام نظام أودوو 🌸</strong>
                        <div class="decor">❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀</div>
                        <p style="margin-top:5px; font-size:11px; font-style:italic; color:#333;">
                            مقدم من إدارة الدعم الفني بشركة <strong>ناصر عوض أل كيرعان – محاسبون ومراجعون قانونيون</strong>، متمنين لكم دوام التميز والرقي.
                        </p>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>

                   
