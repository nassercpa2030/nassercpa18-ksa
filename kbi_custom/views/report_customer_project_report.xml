<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_project_tracking" model="ir.actions.report">
        <field name="name">نموذج تتبع أمر البيع</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_project_tracking</field>
        <field name="print_report_name">f"أمر بيع - {object.name or ''} - {object.partner_id.name or ''}"</field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_customer_project_tracking">
        <t t-foreach="docs" t-as="o">
            <t t-call="kbi_custom.external_layout_seti">

                <style>
                    @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');
                    body, table, td, th { font-family: 'Tajawal', sans-serif; font-size: 13px; }
                    th { font-weight: bold; font-size: 13.5px; background:#EAF3FF; }
                    table { width: 100%; border-collapse: collapse; }
                    td, th { padding:5px; border:1px solid #2F6FB2; text-align:right; vertical-align:middle; }
                    .thank-you { text-align:center; font-size:12px; color:#2F6FB2; }
                    .decor { color:#c71585; margin-top:5px; letter-spacing:2px; }
                    .header-title { font-size:18px; text-align:center; font-weight:bold; margin-bottom:10px; }
                    .signature-cell { width:45%; text-align:center; vertical-align:middle; }
                    strong { display:block; text-align:center; }
                </style>

                <div class="page" style="margin:0;padding:0 0 180px 0;">
                    <!-- عنوان التقرير -->
                    <div class="header-title">تقرير متابعة أمر البيع</div>

                    <table style="margin-top:12px;">
                        <tr>
                            <td width="100%">
                                <table width="100%" style="border-collapse:collapse;">

                                    <!-- تاريخ الطباعة -->
                                    <tr>
                                        <td><strong>تاريخ الطباعة:</strong></td>
                                        <td style="text-align:center;"><span t-field="o.printing_date"/></td>
                                        <td style="text-align:left;">Printing Date</td>
                                    </tr>

                                    <!-- بيانات العميل وأمر البيع -->
                                    <tr>
                                        <td><strong>رقم أمر البيع</strong></td>
                                        <td style="text-align:center;"><span t-field="o.name"/></td>
                                        <td style="text-align:left;"><strong>Sale Order No</strong></td>
                                    </tr>

                                    <tr>
                                        <td><strong>العميل</strong></td>
                                        <td style="text-align:center;"><span t-field="o.partner_id"/></td>
                                        <td style="text-align:left;"><strong>Customer</strong></td>
                                    </tr>

                                    <tr>
                                        <td><strong>تاريخ الطلب</strong></td>
                                        <td style="text-align:center;"><span t-field="o.date_order"/></td>
                                        <td style="text-align:left;"><strong>Order Date</strong></td>
                                    </tr>

                                    <tr>
                                        <td><strong>الخدمة المقدمة </strong></td>
                                        <td style="text-align:center;"><span t-field="o.project_name"/></td>
                                        <td style="text-align:left;"><strong>Provided Service</strong></td>
                                    </tr>

                                    <!-- الدفعات -->
                                    <t t-set="payments" t-value="o.env['account.payment'].search([('sale_order_id','=',o.id)], order='date asc')"/>
                                    <t t-set="payment_count" t-value="len(payments)"/>
                                    <t t-if="payment_count &gt; 0">
                                        <t t-foreach="payments" t-as="pay" t-index="i">
                                            <tr>
                                                <td><strong>الدفعة <t t-esc="i+1"/></strong></td>
                                                <td style="text-align:center;">
                                                    <span t-esc="pay.amount"/> ريال<br/>
                                                    <span t-esc="pay.journal_id.name or '-'"/><br/>
                                                    <small>تاريخ الدفع: <span t-esc="pay.payment_date or '-'"/></small>
                                                </td>
                                                <td style="text-align:left;"><strong>Payment <t t-esc="i+1"/><br/>Bank</strong></td>
                                            </tr>
                                        </t>
                                    </t>
                                    <t t-if="payment_count == 0">
                                        <tr>
                                            <td><strong>الدفعات</strong></td>
                                            <td style="text-align:center;">0</td>
                                            <td style="text-align:left;"><strong>Payments</strong></td>
                                        </tr>
                                    </t>

                                    <!-- الفواتير -->
                                    <t t-set="invoice_count" t-value="len(o.invoice_ids)"/>
                                    <t t-if="invoice_count &gt; 0">
                                        <tr t-foreach="o.invoice_ids" t-as="inv" t-index="i">
                                            <td><strong>الفاتورة <t t-esc="i+1"/></strong></td>
                                            <td style="text-align:center;">
                                                <span t-esc="inv.name or '-'"/> - <span t-esc="inv.date or '-'"/>
                                            </td>
                                            <td style="text-align:left;"><strong>Invoice <t t-esc="i+1"/> - Date</strong></td>
                                        </tr>
                                    </t>
                                    <t t-if="invoice_count == 0">
                                        <tr>
                                            <td><strong>الفاتورة الأولى</strong></td>
                                            <td style="text-align:center;">0</td>
                                            <td style="text-align:left;"><strong>First Invoice - Date</strong></td>
                                        </tr>
                                    </t>

                                    <!-- الإجمالي -->
                                    <tr>
                                        <td><strong>إجمالي أمر البيع قبل الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-esc="o.amount_untaxed or 0"/> ريال</td>
                                        <td style="text-align:left;"><strong>SO Total Before Tax</strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-esc="o.amount_tax or 0"/> ريال</td>
                                        <td style="text-align:left;"><strong>Tax</strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>إجمالي أمر البيع بعد الضريبة</strong></td>
                                        <td style="text-align:center;"><span t-esc="o.amount_total or 0"/> ريال</td>
                                        <td style="text-align:left;"><strong>SO Total After Tax</strong></td>
                                    </tr>

                                    <!-- عدد الأوردر لاينز -->
                                    <tr>
                                        <td><strong>عدد الدفعات:</strong></td>
                                        <td style="text-align:center;" t-esc="payment_count or 0"/>
                                        <td style="text-align:left;"><strong>Number of Payments</strong></td>
                                    </tr>

                                    <!-- توقيعات -->
                                    <!--tr>
                                        <td style="text-align:center;"><strong> توقيع مدير الجودة</strong></td>
                                        <td style="text-align:center;"><strong> توقيع مدير المجموعة</strong></td>
                                        <td style="text-align:center;"><strong> توقيع مدير المالية</strong></td>
                                    </tr>
                                    <tr>
                                        <td colspan="3" style="text-align:center; padding:10px;">
                                            <div>..................................</div>
                                        </td>
                                    </tr-->
                                         <tr>
                                      <td style="text-align:center;"><strong> توقيع مدير الجودة</strong></td>
                                        <td style="text-align:center;"><strong> توقيع مدير المجموعة</strong></td>
                                        <td style="text-align:center;"><strong> توقيع مدير المالية</strong></td>
                        </tr>
                        <tr>
                            <td  colspan="3" style="text-align:center; padding:10px;">..............................</td>
                            <td  colspan="3" style="text-align:center; padding:10px;">..............................</td>
                            <td  colspan="3" style="text-align:center; padding:10px;">..............................</td>
                        </tr>

                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- شكر ودعم نهائي -->
                    <div class="thank-you" style="margin-top:40px; text-align:center; font-size:12px; line-height:1.4;">
                        <strong>🌸🌸🌸 نشكر لكم ثقتكم باستخدام نظام أودوو 🌸🌸🌸</strong>
                        <div class="decor" style="margin:5px 0;">
                            ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀
                        </div>
                        <p style="margin-top:5px; font-size:11px; font-style:italic;">
                            مقدم من إدارة الدعم الفني بشركة 
                            <strong>ناصر عوض أل كيرعان – محاسبون ومراجعون قانونيون</strong>، متمنين لكم دوام التميز والرقي.
                        </p>
                    </div>

                </div>
            </t>
        </t>
    </template>
</odoo>
