                                 <field name="pub_loc903_perc_104" invisible="group_code != '104'"/>
                                 <field name="pub_loc903_perc_110" invisible="group_code != '110'"/>
                                 <field name="pub_loc903_perc_111" invisible="group_code != '111'"/>
                                 <field name="pub_loc903_perc_200" invisible="group_code != '200'"/>
                                <field name="pub_loc903_perc_103" invisible="group_code != '103'"/>
                            </group>
                            <group>
                                <field name="allowed_analytic_plan_ids" invisible="1"/>
                                <field name="allowed_analytic_account_ids" invisible="1"/>
                                <!-- <field name="analytic_account_ids" invisible="1"/>-->
                                <field name="analytic_plan_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True,}"   groups="base.group_system"/> 
                                <field name="show_details"  groups="base.group_system,104__team.shaker"/>
                                <!-- <field name="show_divided"  widget="boolean-toggle" groups="base.group_system,104__team.shaker"/> -->
                       
                                 <field name="level" string="مستوي التقرير" style="background-color:#fff3e0; padding:6px; border-radius:6px; margin-bottom:5px;" groups="base.group_system,104__team.shaker"/>
                              
                                    <field name="show_divided" widget="boolean_toggle" style="background-color:#d1ecf1; padding:6px; border-radius:6px;" groups="base.group_system,104__team.shaker"/>
                             
                      <group class="kbi_divided_buttons_group" text="📊 تقارير المجموعات الموزعة">
<field name="group_code" string="المجموعة المطلوب التوزيع عليها" style="background-color:#f8d7da; padding:6px; border-radius:6px;"
                                   decoration-success="group_code == '101'"
       decoration-info="group_code == '103'"
       decoration-primary="group_code == '104'"
       decoration-warning="group_code == '110'"
       decoration-muted="group_code == '111'"
       decoration-danger="group_code == '200'"
       decoration-bf="group_code != False " groups="base.group_system,104__team.shaker"/>
                          <group class="kbi_divided_title">                              
                         <button name="action_preview_divided_qweb" type="object" string="طباعة QWeb"  invisible="not group_code" class="btn-primary kbi_divided_btn" icon="fa-file-text-o"/>
                        <button name="action_print_divided_excel" type="object" string="طباعة Excel"  invisible="not group_code" lass="btn-success kbi_divided_btn" icon="fa-file-excel-o"/>
                        <button name="action_print_divided_pdf" type="object" string="طباعة PDF" invisible="not group_code"  class="btn-secondary kbi_divided_btn" icon="fa-file-pdf-o"/>
                          </group>
                      </group>
                              
                              <!-- <field name="group_code"
       decoration-success="group_code == '101'"
       decoration-info="group_code == '103'"
       decoration-primary="group_code == '104'"
       decoration-warning="group_code == '110'"
       decoration-muted="group_code == '111'"
       decoration-danger="group_code == '200'"
       decoration-bf="group_code != False " groups="base.group_system,104__team.shaker"/> -->

                                <!-- <field name="level"  groups="base.group_system,104__team.shaker"/> -->
                            </group>
                        </group>
                            <div class="alert alert-info" role="alert">
                            يتم اختيار التقرير على مستوى الخطة التحليلية كاملة. يقوم التقرير بالتجميع حسب الخطة التحليلية  ثم الحساب المالي، ويتم احتساب القيم حسب نسب التوزيع التحليلي وليس كامل قيمة سطر القيد.
                        </div>
                        <!-- <div class="alert alert-info" role="alert">
                            يتم اختيار التقرير على مستوى الخطة التحليلية كاملة. يقوم التقرير بالتجميع حسب الخطة التحليلية ثم الحساب التحليلي ثم الحساب المالي، ويتم احتساب القيم حسب نسب التوزيع التحليلي وليس كامل قيمة سطر القيد.
                        </div> -->
                    </sheet>
                    <footer>
                        <button name="action_preview_qweb_report" type="object" string="Preview QWeb Report" class="btn-primary"/>
                       <button name="action_print_excel_report" type="object" string="Print Excel" class="btn-success" icon="fa-file-excel-o"/>
                            <button name="action_print_pdf_report" type="object" string="Print PDF" class="btn-secondary"/>
                        <button name="action_generate_report" type="object" string="Open Lines" class="btn-secondary" groups="base.group_system,104__team.shaker"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_kbi_analytic_profit_loss_line_tree" model="ir.ui.view">
            <field name="name">kbi.analytic.profit.loss.line.tree</field>
            <field name="model">kbi.analytic.profit.loss.line</field>
            <field name="arch" type="xml">
                <list string="Analytic Profit and Loss" create="0" edit="0" delete="0"
                      decoration-info="line_type == 'plan'"
                      decoration-primary="line_type == 'analytic'"
                      decoration-muted="line_type == 'detail'">
                    <field name="sequence" optional="hide"/>
                    <field name="level" optional="hide"/>
                    <field name="line_type"/>
                    <field name="analytic_plan_id"/>
                    <!-- <field name="analytic_account_id"/> -->
                    <field name="account_code"/>
                    <field name="account_name"/>
                    <field name="date" optional="show"/>
                    <field name="move_id" optional="show"/>
                    <field name="journal_id" optional="hide"/>
                    <field name="partner_id" optional="show"/>
                    <field name="name"/>
                    <field name="percentage" optional="show"/>
                    <field name="original_balance" sum="Original Balance" optional="show"/>
                    <field name="analytic_balance" sum="Analytic Balance"/>
                    <field name="income_amount" sum="Income"/>
                    <field name="expense_amount" sum="Expense"/>
                    <field name="net_amount" sum="Net Profit / Loss"/>
                    <field name="company_currency_id" invisible="1"/>
                </list>
            </field>
        </record>

        <record id="view_kbi_analytic_profit_loss_line_form" model="ir.ui.view">
            <field name="name">kbi.analytic.profit.loss.line.form</field>
            <field name="model">kbi.analytic.profit.loss.line</field>
            <field name="arch" type="xml">
                <form string="Analytic Profit and Loss Line" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="line_type"/>
                                <field name="analytic_plan_id"/>
                                <!-- <field name="analytic_account_id"/> -->
                                <field name="account_id"/>
                                <field name="move_id"/>
                                <field name="move_line_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="partner_id"/>
                                <field name="percentage"/>
                                <field name="original_balance"/>
                                <field name="analytic_balance"/>
                                <field name="income_amount"/>
                                <field name="expense_amount"/>
                                <field name="net_amount"/>
                                <field name="company_currency_id" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_kbi_analytic_profit_loss_line_search" model="ir.ui.view">
            <field name="name">kbi.analytic.profit.loss.line.search</field>
            <field name="model">kbi.analytic.profit.loss.line</field>
            <field name="arch" type="xml">
                <search string="Analytic Profit and Loss">
                    <field name="analytic_plan_id"/>
                    <!-- <field name="analytic_account_id"/> -->
                    <field name="account_id"/>
                    <field name="move_id"/>
                    <filter string="Plans" name="group_by_plan" context="{'group_by': 'analytic_plan_id'}"/>
                    <!-- <filter string="Analytic Accounts" name="group_by_analytic" context="{'group_by': 'analytic_account_id'}"/> -->
                    <filter string="Financial Accounts" name="group_by_account" context="{'group_by': 'account_id'}"/>
                    <filter string="Line Type" name="group_by_line_type" context="{'group_by': 'line_type'}"/>
                </search>
            </field>
        </record>

        <record id="view_kbi_analytic_profit_loss_line_pivot" model="ir.ui.view">
            <field name="name">kbi.analytic.profit.loss.line.pivot</field>
            <field name="model">kbi.analytic.profit.loss.line</field>
            <field name="arch" type="xml">
                <pivot string="Analytic Profit and Loss" disable_linking="1">
                    <field name="analytic_plan_id" type="row"/>
                    <!-- <field name="analytic_account_id" type="row"/> -->
                    <field name="account_id" type="row"/>
                    <field name="income_amount" type="measure"/>
                    <field name="expense_amount" type="measure"/>
                    <field name="net_amount" type="measure"/>
                    <field name="analytic_balance" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_kbi_analytic_profit_loss_wizard" model="ir.actions.act_window">
            <field name="name">Analytic Profit and Loss</field>
            <field name="res_model">kbi.analytic.profit.loss.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_kbi_analytic_profit_loss"
                  name="تقــرير الربــح والخــسارة شــامل المــبالغ المــوزعة"
                  parent="account.menu_finance_reports"
                  action="action_kbi_analytic_profit_loss_wizard"
                  sequence="90"/>

    </data>
</odoo>
