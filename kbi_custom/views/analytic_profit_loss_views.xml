                                <field name="quality901_perc_200"    invisible="group_code != '200'"/>
                                <field name="quality901_perc_103"   invisible="group_code != '103'"/>
                                <field name="oper_supp902_perc_101" invisible="group_code != '101'"/>
                                <field name="oper_supp902_perc_104" invisible="group_code != '104'"/>
                                 <field name="oper_supp902_perc_110" invisible="group_code != '110'"/>
                                 <field name="oper_supp902_perc_111" invisible="group_code != '111'"/>
                                 <field name="oper_supp902_perc_200" invisible="group_code != '200'"/>
                                 <field name="oper_supp902_perc_103" invisible="group_code != '103'"/>
                                 <field name="sale_gen911_perc_101" invisible="group_code != '101'"/>
                                <field name="sale_gen911_perc_104" invisible="group_code != '104'"/>
                                <field name="sale_gen911_perc_110" invisible="group_code != '110'"/>
                                <field name="sale_gen911_perc_111" invisible="group_code != '111'"/>
                                <field name="sale_gen911_perc_200" invisible="group_code != '200'"/>
                                <field name="sale_gen911_perc_103" invisible="group_code != '103'"/>
                                <field name="office_supp_perc_101" invisible="group_code != '101'"/>
                                <field name="office_supp_perc_104" invisible="group_code != '104'"/>
                                <field name="office_supp_perc_110" invisible="group_code != '110'"/>
                                <field name="office_supp_perc_111" invisible="group_code != '111'"/>
                                <field name="office_supp_perc_200" invisible="group_code != '200'"/>
                                <field name="office_supp_perc_103" invisible="group_code != '103'"/>
                                <field name="manage_921_perc_101" invisible="group_code != '101'"/>
                                 <field name="manage_921_perc_104" invisible="group_code != '104'"/>
                                 <field name="manage_921_perc_110" invisible="group_code != '110'"/>
                                 <field name="manage_921_perc_111" invisible="group_code != '111'"/>
                                 <field name="manage_921_perc_200" invisible="group_code != '200'"/>
                                 <field name="manage_921_perc_103" invisible="group_code != '103'"/>
                                 <field name="it_922_perc_101" invisible="group_code != '101'"/>
                                 <field name="it_922_perc_104" invisible="group_code != '104'"/>
                                 <field name="it_922_perc_110" invisible="group_code != '110'"/>
                                 <field name="it_922_perc_111" invisible="group_code != '111'"/>
