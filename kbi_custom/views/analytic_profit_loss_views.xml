                                 <field name="it_922_perc_103" invisible="group_code != '103'"/>
                                <field name="build_facil950_perc_101" invisible="group_code != '101'"/>
                                 <field name="build_facil950_perc_104" invisible="group_code != '104'"/>
                                 <field name="build_facil950_perc_110" invisible="group_code != '110'"/>
                                 <field name="build_facil950_perc_111" invisible="group_code != '111'"/>
                                 <field name="build_facil950_perc_200" invisible="group_code != '200'"/>
                                 <field name="build_facil950_perc_103" invisible="group_code != '103'"/>
                                <field name="coff_clean_ryd_perc_101" invisible="group_code != '101'"/>
                                <field name="coff_clean_ryd_perc_104" invisible="group_code != '104'"/>
                                <field name="coff_clean_ryd_perc_110" invisible="group_code != '110'"/>
                                <field name="coff_clean_ryd_perc_111" invisible="group_code != '111'"/>
                                <field name="coff_clean_ryd_perc_200" invisible="group_code != '200'"/>
                                <field name="coff_clean_ryd_perc_103" invisible="group_code != '103'"/>
