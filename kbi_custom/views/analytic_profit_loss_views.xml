                                <field name="finance923_perc_104"   invisible="group_code != '104'"/>
                                 <field name="finance923_perc_110"   invisible="group_code != '110'"/>
                                 <field name="finance923_perc_111"   invisible="group_code != '111'"/>
                                 <field name="finance923_perc_200"   invisible="group_code != '200'"/>
                                 <field name="finance923_perc_103"   invisible="group_code != '103'"/>
                                 <field name="quality901_perc_101"   invisible="group_code != '101'"/>
