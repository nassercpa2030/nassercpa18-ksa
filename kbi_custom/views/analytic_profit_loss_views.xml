<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_kbi_analytic_profit_loss_wizard_form" model="ir.ui.view">
            <field name="name">kbi.analytic.profit.loss.wizard.form</field>
            <field name="model">kbi.analytic.profit.loss.wizard</field>
            <field name="arch" type="xml">
                <form string="Analytic Profit and Loss">
                    <sheet>
                        <group string="Report Filters">
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <!-- <field name="company_id" groups="base.group_multi_company"/> -->
                                <field name="user_id" invisible="not group_code"/>
