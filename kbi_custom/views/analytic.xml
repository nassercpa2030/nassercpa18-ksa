<odoo>
    <data>

        <record model="ir.ui.view" id="kbi_custom.account_analytic_plan_form_view_inherit">
            <field name="name">kbi_custom.account.analytic.plan.form.view.inherit</field>
            <field name="model">account.analytic.plan</field>
            <field name="inherit_id" ref="analytic.account_analytic_plan_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//page[last()]" position="after">
                    <page string="Approval Routes">
                        <field name="approval_route_ids"/>
                    </page>
                    <page string="Broker">
                        <field name="broker_ids">
                            <list editable="bottom">
                               
                                
                                
                               
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record model="ir.ui.view" id="kbi_custom.account_move_form_view_inherit">
    <field name="name">kbi_custom.account.move.form.view.inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

        <xpath expr="//field[@name='journal_id']" position="after">
                   <field name="employee_id" widget="badge" decoration-success="employee_name != ''"/>
                </xpath>

    </field>
</record>
    </data>
</odoo>
