<odoo>
    <data>

        <record model="ir.ui.view" id="kbi_custom.view_account_payment_form_inherit">
            <field name="name">kbi_custom.view.account.payment.form.inherit</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="model">account.payment</field>
            <field name="arch" type="xml">

                <!-- إضافة حقل multi_sale قبل partner_id -->
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="multi_sale"/>
                </xpath>

                <!-- إضافة sale_order_id بعد partner_bank_id وإخفاء from_sale -->
                <xpath expr="//field[@name='partner_bank_id']" position="after">
                    <field name="sale_order_id" modifiers="{'readonly': sale_order_readonly}"/>
                    <field name="from_sale" invisible="1"/>
                </xpath>

                <!-- تعديل partner_id و payment_type ليكونوا readonly عبر modifiers -->
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="modifiers">{'readonly': partner_readonly}</attribute>
                </xpath>

                <xpath expr="//field[@name='payment_type']" position="attributes">
                    <attribute name="modifiers">{'readonly': partner_readonly}</attribute>
                </xpath>

            </field>
        </record>

        <!-- account.move -->
      <record model="ir.ui.view" id="kbi_custom.view_account_move_form_inherit">
            <field name="name">kbi_custom.view.account.move.form.inherit</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="model">account.move</field>
            <field name="arch" type="xml">
           <xpath expr="//field[@name='checked']" position="after">
                   <field name="vendor_attachment"  widget='image'/>
                </xpath>
            </field>
      </record>
        

    </data>
</odoo>
