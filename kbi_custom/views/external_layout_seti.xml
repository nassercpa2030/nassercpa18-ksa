<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="o" t-value="o"/>
            <t t-set="company" t-value="o.company_id"/>

            <style>
                /* إزالة أي مسافة أعلى وأسفل */
                html, body {
                    margin: 0;
                    padding: 0;
                }

                /* تصميم الهيدر ليحتوي بيانات الشركة والعميل */
                header {
                    display: flex;
                    justify-content: space-between;
                    font-size: 10px;
                    direction: rtl;
                    padding: 0;
                    margin: 0 0 10px 0;
                }

                .company-info {
                    text-align: left;
                    width: 50%;
                }

                .company-info img {
                    max-height: 60px;
                    max-width: 150px;
                    object-fit: contain;
                    display: block;
                    margin-bottom: 5px;
                }

                .client-info {
                    text-align: right;
                    width: 50%;
                }

                /* الفوتر يظهر رقم الصفحة */
                footer {
                    display: block !important;
                    text-align: center;
                    font-size: 10px;
                    color: #555;
                    border-top: 1px solid #ccc;
                    padding-top: 5px;
                }

                /* رسالة شكر أسفل الفاتورة */
                .thank-you {
                    text-align: center;
                    font-size: 12px;
                    margin: 10px 0 5px 0;
                    font-style: italic;
                    color: #333;
                }

                /* الحفاظ على الجوانب */
                .page {
                    margin: 0;
                    padding: 0 15px;
                }
            </style>

            <!-- الهيدر: بيانات الشركة والعميل -->
            <header>
    <div class="company-info">
        <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % company.logo"/>
        <p>
            <strong t-esc="company.name"/>
            <br/>السجل التجاري: <span t-esc="company.company_registry or '-'"/>
            <br/>VAT: <span t-esc="company.vat or '-'"/>
            <br/>العنوان: <span t-esc="company.street or '-'"/>
        </p>
    </div>
    <div class="client-info">
        <p t-if="o">
            <strong>فاتورة إلى:</strong>
            <br/>الاسم: <span t-esc="o.partner_id.name"/>
            <br/>العنوان: <span t-esc="o.partner_id.street or '-'"/>
            <br/>السجل التجاري: <span t-esc="o.partner_id.company_registry or '-'"/>
            <br/>VAT: <span t-esc="o.partner_id.vat or '-'"/>
            <br/><strong>رقم الفاتورة:</strong> <span t-esc="o.name"/>
            <br/><strong>تاريخ الفاتورة:</strong> <span t-esc="o.invoice_date"/>
        </p>
        <p t-else="">
            لا توجد بيانات فاتورة.
        </p>
    </div>
</header>


            <!-- المحتوى الرئيسي -->
            <div class="page">
                <t t-raw="0"/>
            </div>

            <!-- Footer + رسالة شكر -->
            <div class="thank-you">
                شكراً لتعاملكم معنا، نتمنى لكم دوام النجاح والتوفيق
            </div>
            <footer>
                Page <span class="page"/> / <span class="pageCount"/>
            </footer>

        </t>
    </template>
</odoo>
