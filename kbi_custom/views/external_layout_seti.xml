<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="company" t-value="o.company_id"/>

           <style>
    /* استيراد خط Tajawal */
    @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');

    @page {
        size: A4;
        margin: 25mm 15mm 25mm 15mm;
        @bottom-center {
            content: "";
        }
    }

    html, body {
        margin: 0;
        padding: 0;
        direction: rtl;
        font-family: 'Tajawal', sans-serif; /* تغيير الخط هنا */
        color: #555555;
    }

    body {
        font-size: 12px;
        margin-bottom: 70px; /* مساحة كافية للفوتر */
    }

    .page {
        font-size: 12px;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    strong {
        font-size: 13px;
        color: #333333;
    }

    /* HEADER TABLE */
    table.header-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 15px;
        font-weight: bold;
        background-color: #cce6ff;
        border: 2px solid #3399ff;
        font-family: 'Tajawal', sans-serif; /* تأكد من تطبيق الخط على الجدول */
    }

    table.header-table td {
        width: 50%;
        vertical-align: top;
        padding: 10px;
        border: 1px solid #3399ff;
    }

    .company-info { text-align: right; }
    .client-info { text-align: left; }

    img.company-logo {
        max-height: 80px;
        max-width: 180px;
        display: block;
    }

    /* FOOTER */
    .footer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40px;
        text-align: center;
        font-size: 10px;
        border-top: 1px solid #3399ff;
        padding-top: 5px;
        color: #333333;
        font-weight: bold;
        background-color: #cce6ff;
        border: 1px solid #3399ff;
        font-family: 'Tajawal', sans-serif; /* تطبيق الخط على الفوتر */
    }
</style>


            <!-- ================= HEADER ================= -->
            <table class="header-table">
                <tr>
                    <!-- الشركة على اليمين -->
                    <td class="company-info">
                        <strong>بيانات الشركة</strong><br/><br/>
                        <div>
                            <!-- دعم PNG و JPEG -->
                            <img t-if="company.logo"
                                 t-att-src="'data:image/png;base64,%s' % company.logo"
                                 class="company-logo"/>
                            <img t-if="not company.logo and company.logo_jpeg"
                                 t-att-src="'data:image/jpeg;base64,%s' % company.logo_jpeg"
                                 class="company-logo"/>
                        </div>
                        <strong t-esc="company.name"/><br/>
                        <t t-if="company.company_registry">
                            <strong>CR: <span t-esc="company.company_registry"/></strong><br/>
                        </t>
                        <t t-if="company.vat">
                            <strong>VAT: <span t-esc="company.vat"/></strong>
                        </t>
                    </td>

                    <!-- العميل على اليسار -->
                    <td class="client-info">
                        <strong>بيانات العميل</strong><br/><br/>
                        <strong><span t-esc="o.partner_id.name"/></strong><br/>
                        <t t-if="o.partner_id.street">
                            <strong><span t-esc="o.partner_id.street"/></strong><br/>
                        </t>
                        <t t-if="o.partner_id.vat">
                            <strong>VAT: <span t-esc="o.partner_id.vat"/></strong><br/>
                        </t>
                    </td>
                </tr>
            </table>

            <!-- ================= BODY ================= -->
            <div class="page">
                <t t-raw="0"/>
            </div>

            <!-- ================= FOOTER ================= -->
            <div class="footer">
                <strong>صفحة <span class="page"/> / <span class="pageCount"/></strong>
            </div>

        </t>
    </template>
</odoo>
