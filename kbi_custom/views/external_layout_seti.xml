<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="company" t-value="o.company_id"/>

            <style>
                @page {
                    size: A4;
                    margin: 25mm 15mm 25mm 15mm;
                    @bottom-center { content: ""; }
                }

                html, body {
                    margin: 0;
                    padding: 0;
                    direction: rtl;
                    font-family: 'Tajawal', Arial, sans-serif;
                    color: #555555;
                }

                body {
                    font-size: 12px;
                    margin-bottom: 100px; /* مساحة كافية للفوتر */
                }

                .page {
                    font-size: 12px;
                    line-height: 1.6;
                    margin-bottom: 40px;
                }

                strong {
                    font-size: 13px;
                    color: #333333;
                }

                /* HEADER TABLE */
                table.header-table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-bottom: 15px;
                    font-weight: bold;
                    background-color: #e0e0e0; /* خلفية رمادية */
                    border: 1px solid #999999; /* إطار رمادي */
                }

                table.header-table td {
                    width: 50%;
                    vertical-align: top;
                    padding: 10px;
                    border: 1px solid #999999; /* خطوط داخلية رمادية */
                }

                .company-info {
                    text-align: right; /* الشركة على اليمين */
                    font-size: 13px;
                }

                .client-info {
                    text-align: left; /* العميل على اليسار */
                    font-size: 13px;
                }

                img.company-logo {
                    max-height: 80px;
                    max-width: 180px;
                    display: block;
                    margin-bottom: 5px;
                }

                /* FOOTER ثابت في أسفل الصفحة */
                .footer {
                    position: fixed;
                    bottom: 0;
                    left: 0;
                    right: 0;
                    height: auto;
                    text-align: center;
                    font-size: 11px;
                    border-top: 1px solid #999999;
                    padding: 8px 5px 5px 5px;
                    color: #333333;
                    font-weight: bold;
                    background-color: #f0f0f0; /* رمادي فاتح */
                }

                .footer strong {
                    font-size: 12px;
                }
            </style>

            <!-- ================= HEADER ================= -->
            <table class="header-table">
                <tr>
                    <!-- الشركة على اليمين -->
                    <td class="company-info">
                        <strong>بيانات الشركة / Company Info</strong><br/><br/>
                        <div>
                            <!-- دعم PNG و JPEG -->
                            <img t-if="company.logo"
                                 t-att-src="'data:image/png;base64,%s' % company.logo"
                                 class="company-logo"/>
                            <img t-if="not company.logo and company.logo_jpeg"
                                 t-att-src="'data:image/jpeg;base64,%s' % company.logo_jpeg"
                                 class="company-logo"/>
                        </div>
                        <strong t-esc="company.name"/><br/>
                        <t t-if="company.company_registry">
                            <strong>السجل التجاري / CR: <span t-esc="company.company_registry"/></strong><br/>
                        </t>
                        <t t-if="company.vat">
                            <strong>الضريبي / VAT: <span t-esc="company.vat"/></strong>
                        </t>
                    </td>

                    <!-- العميل على اليسار -->
                    <td class="client-info">
                        <strong>بيانات العميل / Customer Info</strong><br/><br/>
                        <strong><span t-esc="o.partner_id.name"/></strong><br/>
                        <t t-if="o.partner_id.street">
                            <strong><span t-esc="o.partner_id.street"/></strong><br/>
                        </t>
                        <t t-if="o.partner_id.vat">
                            <strong>الضريبي / VAT: <span t-esc="o.partner_id.vat"/></strong><br/>
                        </t>
                    </td>
                </tr>
            </table>

            <!-- ================= BODY ================= -->
            <div class="page">
                <t t-raw="0"/>
            </div>

            <!-- ================= FOOTER ================= -->
            <div class="footer">
                <strong>
                    <t t-esc="o.company_id.name"/>
                    <t t-if="o.company_id.phone"> | Tel: <t t-esc="o.company_id.phone"/></t>
                    <t t-if="o.company_id.email"> | Email: <t t-esc="o.company_id.email"/></t>
                    <t t-if="o.company_id.website"> | <t t-esc="o.company_id.website"/></t>
                </strong>
                <br/>
                <strong>صفحة <span class="page"/> / <span class="pageCount"/></strong>
            </div>

        </t>
    </template>
</odoo>
