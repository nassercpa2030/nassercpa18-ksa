<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="company" t-value="o.company_id"/>

           <style>
    /* استيراد خط Tajawal */
       @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');
    @page {
        size: A4;
        margin: 25mm 15mm 25mm 15mm;
        @bottom-center {
            content: "";
        }
    }

    html, body {
        margin: 0;
        padding: 0;
        direction: rtl;
        font-family: 'Tajawal', sans-serif;
        color: #555555;
    }

    body {
        font-size: 12px;
        margin-bottom: 90px; /* مساحة كافية للفوتر */
    }

    .page {
        font-size: 12px;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    strong {
        font-size: 13px;
        color: #333333;
    }

    /* HEADER TABLE */
    table.header-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 15px;
        font-weight: bold;
        background-color: #e0e0e0; /* رمادي فاتح */
        border: 2px solid #999999; /* رمادي غامق */
        font-family: 'Tajawal', sans-serif;
    }

    table.header-table td {
        width: 50%;
        vertical-align: top;
        padding: 10px;
        border: 1px solid #999999;
    }

    .company-info { text-align: right; }
    .client-info { text-align: left; }

    img.company-logo {
        max-height: 80px;
        max-width: 180px;
        display: block;
    }

    /* FOOTER */
    .footer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 60px;
        text-align: center;
        font-size: 11px;
        border-top: 1px solid #999999;
        padding-top: 5px;
        color: #333333;
        font-weight: bold;
        background-color: #f2f2f2; /* فاتح للفوتر */
        font-family: 'Tajawal', sans-serif;
    }

    .footer span {
        display: block;
        margin: 2px 0;
    }
</style>

            <!-- ================= HEADER ================= -->
            <table class="header-table">
                <tr>
                    <!-- الشركة على اليمين -->
                    <td class="company-info">
                        <strong>بيانات الشركة</strong><br/><br/>
                        <div>
                            <img t-if="company.logo"
                                 t-att-src="'data:image/png;base64,%s' % company.logo"
                                 class="company-logo"/>
                            <img t-if="not company.logo and company.logo_jpeg"
                                 t-att-src="'data:image/jpeg;base64,%s' % company.logo_jpeg"
                                 class="company-logo"/>
                        </div>
                        <strong t-esc="company.name"/><br/>
                        <t t-if="company.company_registry">
                            <strong>CR: <span t-esc="company.company_registry"/></strong><br/>
                        </t>
                           <t t-if="company.street">
                            <strong> <span t-esc="company.street"/> , <span t-esc="company.state_id.name"/></strong><br/>
                               <strong></strong><span t-esc="company.country_id.name"/><br/>
                        </t>
                        <t t-if="company.vat">
                            <strong>VAT(الرقم الضريبي): <span t-esc="company.vat"/></strong><br/>
                        </t>
                    </td>

                    <!-- العميل على اليسار -->
                    <td class="client-info">
                        <strong>بيانات العميل</strong><br/><br/>
                        <strong><span t-esc="o.partner_id.name"/></strong><br/>
                        <t t-if="o.partner_id.street">
                            <strong><span t-esc="o.partner_id.street"/></strong><br/>
                        </t>
                        <t t-if="o.partner_id.cr_number_sale">
                            <strong>CR(السجل التجاري):<span t-esc="o.partner_id.cr_number_sale"/></strong><br/>
                        </t>
                          <t t-if="o.partner_id.number_700">
                            <strong>Unified_number(الرقم الموحد):<span t-esc="o.partner_id.number_700"/></strong><br/>
                        </t>
                        <t t-if="o.partner_id.vat">
                            <strong>VAT(الرقم الضربيي): <span t-esc="o.partner_id.vat"/></strong><br/>
                        </t>
                    </td>
                </tr>
            </table>

            <!-- ================= BODY ================= -->
            <div class="page">
                <t t-raw="0"/>
            </div>

    

            <!-- ================= FOOTER ================= -->
<div class="footer" style="font-family: Verdana, Geneva, sans-serif; font-size: 10px; display: flex; justify-content: center; align-items: center; gap: 15px;">
    <t t-if="company.name"><span><strong><t t-esc="company.name"/></strong></span></t>
    <t t-if="company.phone"><span>Tel: <t t-esc="company.phone"/></span></t>
    <t t-if="company.email"><span>Email: <t t-esc="company.email"/></span></t>
    <t t-if="company.website"><span>Website: <t t-esc="company.website"/></span></t>
    <span style="background-color: #d9d9d9; padding: 2px 6px; border-radius: 4px;">
       <strong> <span class="pageCount"/>  / صفحة <span class="page"/> </strong>
    </span>
</div>

        </t>
    </template>
</odoo>


