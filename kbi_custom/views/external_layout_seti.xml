<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="company" t-value="o.company_id"/>

            <style>
                /* استيراد خط Tajawal */
                @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');

                html, body {
                    margin: 0;
                    padding: 0;
                    direction: rtl;
                    font-family: 'Tajawal', Arial, sans-serif;
                    color: #555555;
                }

                body {
                    font-size: 12px;
                    margin-bottom: 120px; /* مساحة كافية للفوتر */
                }

                .page {
                    font-size: 12px;
                    line-height: 1.6;
                    margin-bottom: 40px;
                }

                strong {
                    font-size: 13px;
                    color: #333333;
                }

                /* HEADER TABLE */
                table.header-table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-bottom: 15px;
                    font-weight: bold;
                    background-color: #dcdcdc; /* رمادي */
                    border: 1px solid #999999;
                }

                table.header-table td {
                    width: 50%;
                    vertical-align: top;
                    padding: 10px;
                }

                .company-info {
                    text-align: right; /* الشركة على اليمين */
                }

                .client-info {
                    text-align: left; /* العميل على اليسار */
                }

                img.company-logo {
                    max-height: 80px;
                    max-width: 180px;
                    display: block;
                }

                /* FOOTER ثابت في أسفل الصفحة */
                .footer {
                    position: fixed;
                    bottom: 0;
                    left: 0;
                    right: 0;
                    height: 50px;
                    background-color: #f2f2f2;
                    font-size: 10px;
                    text-align: center;
                    line-height: 1.3;
                    border-top: 1px solid #999999;
                }

                .footer table {
                    width: 100%;
                    border-collapse: collapse;
                }

                .footer td {
                    padding: 3px 5px;
                    text-align: center;
                }
            </style>

            <!-- ================= HEADER ================= -->
            <table class="header-table">
                <tr>
                    <!-- الشركة على اليمين -->
                    <td class="company-info">
                        <strong>Company Info / بيانات الشركة</strong><br/><br/>
                        <div>
                            <img t-if="company.logo"
                                 t-att-src="'data:image/png;base64,%s' % company.logo"
                                 class="company-logo"/>
                            <img t-if="not company.logo and company.logo_jpeg"
                                 t-att-src="'data:image/jpeg;base64,%s' % company.logo_jpeg"
                                 class="company-logo"/>
                        </div>
                        <strong t-esc="company.name"/><br/>
                        <t t-if="company.company_registry">
                            <strong>CR / السجل التجاري: <span t-esc="company.company_registry"/></strong><br/>
                        </t>
                        <t t-if="company.vat">
                            <strong>VAT / الضريبي: <span t-esc="company.vat"/></strong>
                        </t>
                    </td>

                    <!-- العميل على اليسار -->
                    <td class="client-info">
                        <strong>Customer Info / بيانات العميل</strong><br/><br/>
                        <strong><span t-esc="o.partner_id.name"/></strong><br/>
                        <t t-if="o.partner_id.street">
                            <strong><span t-esc="o.partner_id.street"/></strong><br/>
                        </t>
                        <t t-if="o.partner_id.vat">
                            <strong>VAT / الضريبي: <span t-esc="o.partner_id.vat"/></strong><br/>
                        </t>
                    </td>
                </tr>
            </table>

            <!-- ================= BODY ================= -->
            <div class="page">
                <t t-raw="0"/>
            </div>

            <!-- ================= FOOTER ================= -->
            <div class="footer">
                <table>
                    <tr>
                        <td>
                            <strong>
                                <t t-esc="o.company_id.name"/>
                                <t t-if="o.company_id.phone"> | Tel: <t t-esc="o.company_id.phone"/></t>
                                <t t-if="o.company_id.email"> | Email: <t t-esc="o.company_id.email"/></t>
                                <t t-if="o.company_id.website"> | <t t-esc="o.company_id.website"/></t>
                            </strong>
                        </td>
                    </tr>
                </table>
            </div>

        </t>
    </template>
</odoo>
