<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.minimal_layout"> <!-- استخدام minimal_layout لإزالة الهيدر والفوتر -->
            <t t-set="o" t-value="o"/>
            <t t-set="company" t-value="o.company_id"/>

            <!-- إزالة المسافة من فوق فقط -->
            <style>
                body {
                    margin-top: 0 !important;
                    padding-top: 0 !important;
                }

                /* حافظ على المسافة الجانبية الطبيعية */
                .page {
                    margin-left: auto;
                    margin-right: auto;
                    padding-left: 15px;
                    padding-right: 15px;
                }
            </style>

            <t t-raw="0"/>
        </t>
    </template>
</odoo>
