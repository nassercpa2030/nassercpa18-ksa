<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="company" t-value="o.company_id"/>

            <style>
                html, body {
                    margin: 0;
                    padding: 0;
                    direction: rtl;
                }

                body {
                    font-size: 12px;
                }

                .page {
                    font-size: 12px;
                    line-height: 1.6;
                    margin-bottom: 40px; /* مساحة للفوتر */
                }

                strong {
                    font-size: 13px;
                }

                /* HEADER */
                table.header-table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-bottom: 12px;
                }

                table.header-table td {
                    width: 50%;
                    vertical-align: top;
                }

                .company-info {
                    text-align: left;
                    padding-top: 12px;
                }

                .client-info {
                    text-align: right;
                }

                /* FOOTER */
                .footer {
                    position: fixed;
                    bottom: 0;
                    left: 0;
                    right: 0;
                    text-align: center;
                    font-size: 10px;
                    border-top: 1px solid #ccc;
                    padding-top: 5px;
                }
            </style>

            <!-- ================= HEADER ================= -->
            <table class="header-table">
                <tr>
                    <td class="client-info">
                        <strong>فاتورة إلى:</strong><br/>
                        <span t-esc="o.partner_id.name"/><br/>
                        <span t-if="o.partner_id.street" t-esc="o.partner_id.street"/><br/>
                        <t t-if="o.partner_id.vat">
                            VAT: <span t-esc="o.partner_id.vat"/><br/>
                        </t>
                        <strong>رقم الفاتورة:</strong>
                        <span t-esc="o.name"/><br/>
                        <strong>التاريخ:</strong>
                        <span t-esc="o.invoice_date"/>
                    </td>

                    <td class="company-info">
                        <div>
                            <img t-if="company.logo"
                                 t-att-src="'data:image/png;base64,%s' % company.logo"
                                 style="max-height:65px; display:block;"/>
                        </div>

                        <strong t-esc="company.name"/><br/>
                        <t t-if="company.company_registry">
                            CR: <span t-esc="company.company_registry"/><br/>
                        </t>
                        <t t-if="company.vat">
                            VAT: <span t-esc="company.vat"/>
                        </t>
                    </td>
                </tr>
            </table>

            <!-- ================= BODY ================= -->
            <div class="page">
                <t t-raw="0"/>
            </div>

            <!-- ================= FOOTER ================= -->
            <div class="footer">
                صفحة <span class="page"/> / <span class="pageCount"/>
            </div>

        </t>
    </template>
</odoo>
