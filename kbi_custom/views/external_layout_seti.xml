<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <!-- تعيين الشركة لاستخدامها في الفوتر والهيدر -->
            <t t-set="company" t-value="o.company_id"/>

            <style>
                /* استيراد خط Tajawal */
               
                @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');

                html, body {
                    margin: 0;
                    padding: 0;
                    direction: rtl;
                    font-family: 'Tajawal', Arial, sans-serif;
                    color: #555555;
                    font-size: 12px;
                }

                body {
                    margin-bottom: 90px; /* مساحة كافية للفوتر */
                }

                .page {
                    font-size: 12px;
                    line-height: 1.6;
                    margin-bottom: 20px;
                }

                strong {
                    font-size: 13px;
                    color: #333333;
                }

                /* ================= HEADER ================= */
                table.header-table {
                    width: 100%;
                    border-collapse: collapse;
                    margin-bottom: 15px;
                    font-weight: bold;
                    background-color: #dcdcdc;
                    border: 1px solid #999999;
                }

                table.header-table td {
                    width: 50%;
                    vertical-align: top;
                    padding: 10px;
                }

                .company-info { text-align: right; }
                .client-info { text-align: left; }

                img.company-logo {
                    max-height: 80px;
                    max-width: 180px;
                    display: block;
                }

                /* ================= FOOTER ================= */
                table.footer-table {
                    width: 100%;
                    border-collapse: collapse;
                    font-size: 11px;
                    font-family: 'Tajawal', Arial, sans-serif;
                    background-color: #f2f2f2;
                    margin-top: 10px;
                    text-align: center;
                    font-weight: bold;
                    border-top: 1px solid #999999;
                }

                table.footer-table td {
                    padding: 5px 10px;
                }

                /* أرقام الصفحة */
                .page-number:before { content: counter(page); }
                .total-pages:before { content: counter(pages); }

            </style>

            <!-- ================= HEADER ================= -->
            <table class="header-table">
                <tr>
                    <td class="company-info">
                        <strong>Company Info / بيانات الشركة</strong><br/><br/>
                        <div>
                            <img t-if="company.logo"
                                 t-att-src="'data:image/png;base64,%s' % company.logo"
                                 class="company-logo"/>
                            <img t-if="not company.logo and company.logo_jpeg"
                                 t-att-src="'data:image/jpeg;base64,%s' % company.logo_jpeg"
                                 class="company-logo"/>
                        </div>
                        <strong t-esc="company.name"/><br/>
                        <t t-if="company.company_registry">
                            <strong>CR / السجل التجاري: <span t-esc="company.company_registry"/></strong><br/>
                        </t>
                        <t t-if="company.vat">
                            <strong>VAT / الضريبي: <span t-esc="company.vat"/></strong>
                        </t>
                    </td>

                    <td class="client-info">
                        <strong>Customer Info / بيانات العميل</strong><br/><br/>
                        <strong><span t-esc="o.partner_id.name"/></strong><br/>
                        <t t-if="o.partner_id.street">
                            <strong><span t-esc="o.partner_id.street"/></strong><br/>
                        </t>
                        <t t-if="o.partner_id.vat">
                            <strong>VAT / الضريبي: <span t-esc="o.partner_id.vat"/></strong><br/>
                        </t>
                    </td>
                </tr>
            </table>

            <!-- ================= BODY ================= -->
            <div class="page">
                <t t-raw="doc_body"/>
            </div>

            <!-- ================= FOOTER ================= -->
            <table class="footer-table">
                <tr>
                    <td>
                        <strong>
                            <t t-esc="company.name"/>
                            <t t-if="company.phone"> | Tel: <t t-esc="company.phone"/></t>
                            <t t-if="company.email"> | Email: <t t-esc="company.email"/></t>
                            <t t-if="company.website"> | <t t-esc="company.website"/></t>
                        </strong>
                        <br/>
                        <span>صفحة <span class="page-number"/> من <span class="total-pages"/></span>
                    </td>
                </tr>
            </table>

        </t>
    </template>
</odoo>
