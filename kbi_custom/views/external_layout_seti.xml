<?xml version="1.0" encoding="utf-8"?>
<odoo>
 <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="company" t-value="o.company_id"/>

            <style>
                html, body { margin:0; padding:0; }
                header {
                    display:flex;
                    justify-content:space-between;
                    font-size:10px;
                    direction:rtl;
                    margin-bottom:10px;
                }
                .company-info { width:50%; text-align:left; }
                .client-info  { width:50%; text-align:right; }
                footer {
                    text-align:center;
                    font-size:10px;
                    border-top:1px solid #ccc;
                    margin-top:10px;
                }
            </style>

            <!-- HEADER -->
            <header>
                <div class="company-info">
                    <img t-if="company.logo"
                         t-att-src="'data:image/png;base64,%s' % company.logo"
                         style="max-height:60px"/>
                    <p>
                        <strong t-esc="company.name"/><br/>
                        CR: <span t-esc="company.company_registry"/><br/>
                        VAT: <span t-esc="company.vat"/>
                    </p>
                </div>

                <div class="client-info">
                    <p>
                        <strong>فاتورة إلى:</strong><br/>
                        <span t-esc="o.partner_id.name"/><br/>
                        <span t-esc="o.partner_id.street"/><br/>
                        VAT: <span t-esc="o.partner_id.vat"/><br/>
                        <strong>رقم الفاتورة:</strong> <span t-esc="o.name"/><br/>
                        <strong>التاريخ:</strong> <span t-esc="o.invoice_date"/>
                    </p>
                </div>
            </header>

            <!-- BODY -->
            <div class="page">
                <t t-raw="0"/>
            </div>

            <!-- FOOTER -->
            <footer>
                Page <span class="page"/> / <span class="pageCount"/>
            </footer>

        </t>
    </template>    
</odoo>
