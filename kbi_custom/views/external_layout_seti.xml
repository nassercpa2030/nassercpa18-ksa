<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_seti">
        <t t-call="web.basic_layout">
            <t t-set="o" t-value="o"/>
            <t t-set="company" t-value="o.company_id"/>

            <!-- إزالة الهيدر والفوتر تماماً -->
            <t t-set="no_header_footer" t-value="True"/>

            <!-- مسح أي padding من البودي -->
            <style>
                body {
                    margin: 0 !important;
                    padding: 0 !important;
                }
                .page {
                    margin: 0 !important;
                    padding: 0 !important;
                }
            </style>

            <t t-raw="0"/>
        </t>
    </template>
</odoo>
