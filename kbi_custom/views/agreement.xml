<odoo>
    <data>

        <!-- Sale Agreement Form View -->
        <record model="ir.ui.view" id="kbi_custom.view_kbi_sale_agreement_form">
            <field name="name">kbi_custom.view.kbi.sale.agreement.form</field>
            <field name="model">kbi.sale.agreement</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar"/>
                        <button name="action_confirm" string="Confirm" type="object" class="btn btn-primary"
                                modifiers="{'invisible': [('state', '!=', 'draft')]}"/>
                        <button name="action_cancel" string="Cancel" type="object" class="btn btn-secondary"
                                modifiers="{'invisible': [('state', '=', 'cancel')]}"/>
                        <button name="action_print_wizard" string="Print" type="object" class="btn btn-primary"
                                modifiers="{'invisible': [('state', '!=', 'confirm')]}"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" name="action_open_payment" type="object" icon="fa-money">
                                <field name="payment_count" widget="statinfo" string="Payments"/>
                            </button>
                        </div>
                        <div class="row">
                            <div class="col-6"/>
                            <div class="col-6">
                                <div class="row text-center h3 text-black">
                                    <div class="col-4">
                                        <label for="paid_total"/>
                                        <field name="paid_total" modifiers="{'readonly': True}"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="unpaid_total"/>
                                        <field name="unpaid_total" modifiers="{'readonly': True}"/>
                                    </div>
                                    <div class="col-4">
                                        <label for="paid_percent"/>
                                        <field name="paid_percent" modifiers="{'readonly': True}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" modifiers="{'readonly': True}"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="ref"/>
                                <field name="partner_id" required="1"/>
                                <field name="email_from" modifiers="{'readonly': True}"/>
                                <field name="phone" modifiers="{'readonly': True}"/>
                                <field name="vat_number" modifiers="{'readonly': True}"/>
                                <field name="cr_number" modifiers="{'readonly': True}"/>
                                <field name="analytic_plan_id" modifiers="{'readonly': True}"/>
                            </group>
                            <group>
                                <label for="street_page_lead" string="Address"/>
                                <div class="o_address_format">
                                    <field name="street" id="street_page_lead" class="o_address_street" modifiers="{'readonly': True}"/>
                                    <field name="street2" class="o_address_street" modifiers="{'readonly': True}"/>
                                    <field name="building_number" modifiers="{'readonly': True}"/>
                                    <field name="polt_number" modifiers="{'readonly': True}"/>
                                    <field name="city_id" class="o_address_city" modifiers="{'readonly': True}"/>
                                    <field name="state_id" class="o_address_state" options="{'no_open': True}" modifiers="{'readonly': True}"/>
                                    <field name="zip" class="o_address_zip" modifiers="{'readonly': True}"/>
                                    <field name="country_id" class="o_address_country" options="{'no_open': True, 'no_create': True}" modifiers="{'readonly': True}"/>
                                </div>
                                <field name="lead_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

 
        <!-- Action -->
        <record model="ir.actions.act_window" id="kbi_custom.action_kbi_sale_agreement">
            <field name="name">Agreements</field>
            <field name="res_model">kbi.sale.agreement</field>
            <field name="view_mode">tree,form,pivot</field>
        </record>

        <!-- Menu -->
        <menuitem name="Agreements" id="kbi_custom.menu_kbi_sale_agreement"
                  sequence="20" parent="sale.sale_order_menu" action="kbi_custom.action_kbi_sale_agreement"/>

        <!-- Print Wizard -->
        <record model="ir.ui.view" id="kbi_custom.view_kbi_sale_agreement_print_wizard">
            <field name="name">kbi_custom.view.kbi.sale.agreement.print.wizard</field>
            <field name="model">kbi.sale.agreement.print.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="agreement_id"/>
                                <field name="printed_order_ids" widget="many2many_tags"/>
                                <field name="report_id"/>
                            </group>
                            <group>
                                <field name="order_ids" modifiers="{'invisible': True}"/>
                                <field name="report_template_ids" modifiers="{'invisible': True}"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Print" name="action_print" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
