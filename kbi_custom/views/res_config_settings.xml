<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_config_broker_inherit" model="ir.ui.view">
            <field name="name">Accounting Broker settings</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <!-- إضافة مجموعة Broker Settings في أعلى مستوى -->
                <xpath expr="." position="inside">
                    <group string="Broker Settings" name="broker_settings_group">
                        <group>
                            <field name="broker_comm_product_id"/>
                            <field name="broker_comm_journal_id"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
