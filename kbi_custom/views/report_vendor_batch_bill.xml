<?xml version="1.0" encoding="utf-8"?>
<odoo>
     
     <!-- تعريف التقرير وربطه بنموذج فواتير الموردين -->
    <record id = "action_report_vendor_batch_bill_report" model="ir.actions.report">
        <field name="name">طلب صرف عمولة مسوق بالقطعة</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_vendor_batch_bill_template</field>
        <field name="print_report_name">'تقرير_طلب_صرف_عمولة_الموردين.pdf'</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- قالب QWeb لتصميم شكل التقرير -->
    <template id="report_vendor_batch_bill_template">
        <t t-set="company" t-value="docs[0].company_id"/>
        <t t-call="web.html_container">
            <!--t t-call="web.external_layout_standard"-->
              <t t-call="web.html_container">
                <div class="page">
                    <!-- عنوان التقرير -->
                    <h2 style="text-align: center; direction: rtl;">طلب صرف مكافأة مسوق بالقطعة </h2>
                    <!-- p style="text-align: center; direction: rtl;">
                        تاريخ الطباعة: 
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                    </p-->
                   <p style="text-align: center;">
                 <span>***********************************************</span>
                 </p>

                   <table style="width:100%; direction: rtl; border-collapse: collapse;"> 
                       <tr> <!-- العمود الأول: النصوص --> 
                           <td style="width:70%; vertical-align: top; text-align: right; padding: 5px;"> 
                               <p style="font-size:10px; margin: 3px 0;"> التاريخ: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/> </p>
                               <p style="margin: 3px 0;"> المسوق: <span t-field="docs[0].partner_id.name"/> </p> 
                               <p style="margin: 3px 0;"> مدير المجموعة: <span t-field="docs[0].sale_order_id_finance.user_id.name"/> </p> 
                               <p style="margin: 3px 0;"> مجموعة: <span t-field="docs[0].sale_order_id_finance.team_id.name"/> </p>
                           </td>
                           <!-- العمود الثاني: الصورة --> 
                           <td style="width:30%; vertical-align: top; text-align: left; padding: 5px; padding-top:-200px">
                               <t t-if="docs[0].partner_id.image_1920"> 
                                   <img t-att-src="'data:image/png;base64,%s' % (docs[0].partner_id.image_1920.decode() if isinstance(docs[0].partner_id.image_1920, bytes) else docs[0].partner_id.image_1920)" style="max-width:300px;height:auto;max-height:300px; border:2px solid #000; image-rendering: crisp-edges"/> 
                               </t> </td> </tr> </table>
                    <hr/>

                    <!-- الجدول الذي سيحتوي على البيانات -->
                    <table class="table table-bordered" style="width: 100%; direction: rtl; font-size: 10px;">
                        <thead style="background-color: #f0f0f0;">
                            <tr>
                                <th style="padding: 8px; text-align: center;">رقم الفاتورة</th>
                                <th style="padding: 8px; text-align: center;">أسم العميل</th>
                                <th style="padding: 8px; text-align: center;">أمر البيع</th>
                                <th style="padding: 8px; text-align: center;">إسم المشروع</th>
                                <th style="padding: 8px; text-align: center;">قيمة العقد</th>
                                <th style="padding: 8px; text-align: center;">نسبة العمولة</th>
                                <th style="padding: 8px; text-align: center;">قيمة فاتورة المسوق</th>
                                <th style="padding: 8px; text-align: center;">المبلغ المستحق</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- تهيئة متغير المجموع -->
                            <t t-set="total_sum" t-value="0.0"/> 
                            <t t-set="amount_residual_sig" t-value="0.0"/> 

                            <!-- المرور على جميع الفواتير -->
                            <t t-foreach="docs" t-as="bill">
                                <tr>
                                    <td style="padding: 8px;"><span t-field="bill.name"/></td>
                                    <td style="padding: 8px;"><span t-field="bill.sale_order_id_finance.partner_id.name" /></td>
                                    <td style="padding: 8px;"><span t-field="bill.sale_order_id_finance.name" t-if="bill.sale_order_id_finance"/></td>
                                    <td style="padding: 7px; text-align: center;"><span t-field="bill.sale_order_id_finance.project_name" t-if="bill.sale_order_id_finance"/></td>
                                    <td style="padding: 10px; text-align: center;"><span t-field="bill.sale_order_id_finance.amount_untaxed" t-if="bill.sale_order_id_finance"/></td>
                                    <td style="padding: 7px; text-align: center;"><span t-field="bill.sale_order_id_finance.broker_percentage_" t-if="bill.sale_order_id_finance"/>
                                    <b>%</b>
                                    </td>
                                    <td style="padding: 8px; text-align: left;">
                                        <span t-field="bill.amount_total" t-options='{"widget": "monetary", "display_currency": bill.currency_id}'/>
                                    </td>
                                      <td style="padding: 8px; text-align: left;">
                                        <span t-field="bill.amount_residual_signed" t-options='{"widget": "monetary", "display_currency": bill.currency_id}'/>
                                    </td>
                                    
                                    <!-- تحديث المجموع -->
                                    <t t-set="total_sum" t-value="total_sum + (bill.amount_total or 0.0)"  />
                                    <t t-set="amount_residual_sig" t-value="amount_residual_sig + (bill.amount_residual_signed or 0.0)"  />
                                </tr>
                            </t>
                            
                              <tr style="font-weight:bold; border-top: 2px solid black;">
                                <td colspan="7" style="text-align:right; padding:8px;">  إجمالي المبلغ المستحق:</td>
                                <td style="padding:8px; text-align:left;">
                                    <span t-esc="'{:,.2f}'.format(amount_residual_sig or 0.0)"  />
                                </td>
                            </tr>
                            <!-- صف المجموع النهائي -->
                            <tr style="font-weight:bold; border-top: 2px solid black;">
                                <td colspan="6" style="text-align:right; padding:8px;">إجمالي المبالغ:</td>
                                <td style="padding:8px; text-align:left;">
                                    <span t-esc="'{:,.2f}'.format(total_sum or 0.0)"  />
                                </td>
                            </tr>
                             
                        </tbody>
                    </table>
                    <hr/>

                    <!-- توقيع الإعداد والمراجعة والإعتماد -->
                    <div style="display: flex; justify-content: space-between; margin-bottom: 15px; direction: rtl;">
                        <div style="display: inline-block; width: 33%; text-align: right;">
                            <span style="text-decoration: underline;">إعداد</span>
                        </div>
                        <div style="display: inline-block; width: 33%; text-align: center;">
                            <span style="text-decoration: underline;">مراجعة</span>
                        </div>
                        <div style="display: inline-block; width: 33%; text-align: left;">
                            <span style="text-decoration: underline;">إعتماد</span>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>







