<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_vendor_batch_bill_report" model="ir.actions.report">
        <field name="name">طلب صرف عمولة مسوق بالقطعة</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_vendor_batch_bill_template</field>
        <field name="print_report_name">'تقرير_طلب_صرف_عمولة_الموردين.pdf'</field>
          <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_vendor_batch_bill_template">
        <t t-call="kbi_custom.external_layout_batch_bill">
            <table class="table table-bordered" style="width:100%; font-size:10px; border-collapse: collapse;">
                <thead style="background-color:#f0f0f0;">
                    <tr>
                        <th style="padding:8px; text-align:center;">رقم الفاتورة</th>
                        <th style="padding:8px; text-align:center;">أسم العميل</th>
                        <th style="padding:8px; text-align:center;">أمر البيع</th>
                        <th style="padding:8px; text-align:center;">إسم المشروع</th>
                        <th style="padding:8px; text-align:center;">قيمة العقد</th>
                        <th style="padding:8px; text-align:center;">نسبة العمولة</th>
                        <th style="padding:8px; text-align:center;">قيمة فاتورة المسوق</th>
                        <th style="padding:8px; text-align:center;">المبلغ المستحق</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="total_sum" t-value="0.0"/>
                    <t t-set="amount_residual_sig" t-value="0.0"/>

                    <t t-foreach="docs" t-as="o">
                        <tr>
                            <td style="padding:8px;"><strong><span t-field="o.name"/></strong></td>
                            <td style="padding:8px;"><strong><span t-field="o.sale_order_id_finance.partner_id.name"/></strong></td>
                            <td style="padding:8px;"><strong><span t-field="o.sale_order_id_finance.name" t-if="o.sale_order_id_finance"/></strong></td>
                            <td style="padding:8px; text-align:center;"><strong><span t-field="o.sale_order_id_finance.project_name" t-if="o.sale_order_id_finance"/></strong></td>
                            <td style="padding:8px; text-align:center;"><strong><span t-field="o.sale_order_id_finance.amount_untaxed" t-if="o.sale_order_id_finance"/></strong></td>
                            <td style="padding:8px; text-align:center;"><strong><span t-field="o.sale_order_id_finance.broker_percentage_" t-if="o.sale_order_id_finance"/>%</strong></td>
                            <td style="padding:8px; text-align:left;"><strong><span t-field="o.amount_total" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></strong></td>
                            <td style="padding:8px; text-align:left;"><strong><span t-field="o.amount_residual_signed" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></strong></td>

                            <t t-set="total_sum" t-value="total_sum + (o.amount_total or 0.0)"/>
                            <t t-set="amount_residual_sig" t-value="amount_residual_sig + (o.amount_residual_signed or 0.0)"/>
                        </tr>
                    </t>

                    <tr style="font-weight:bold; border-top:2px solid black;">
                        <td colspan="7" style="text-align:right; padding:8px;">إجمالي المبلغ المستحق:</td>
                        <td style="padding:8px; text-align:left;"><strong><span t-esc="'{:,.2f}'.format(amount_residual_sig or 0.0)"/> SR</strong></td>
                    </tr>

                    <tr style="font-weight:bold; border-top:2px solid black;">
                        <td colspan="6" style="text-align:right; padding:8px;">إجمالي المبالغ:</td>
                        <td style="padding:8px; text-align:left;"><strong><span t-esc="'{:,.2f}'.format(total_sum or 0.0)"/> SR</strong></td>
                    </tr>
                </tbody>
            </table>
                                <!-- توقيع الإعداد والمراجعة والإعتماد -->
<!-- CSS مركزي للتوقيعات -->
<style>
  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');

.signature-table {
    width: 100%;
    direction: rtl;
    border-collapse: collapse;
    margin-top: 10px;
    font-family: 'Tajawal', sans-serif;
}

.signature-table td {
    width: 33.33%;           /* كل عمود متساوي */
    text-align: center;
    vertical-align: top;
    padding: 0;
    border: 1px solid transparent !important;
    outline: none !important;
}

.signature-texts {
    font-weight: bold;
    text-decoration: underline;
    margin-bottom: 5px; /* مسافة بين النصوص والصور */
}

.signature-images img {
    display: block;
    height: 80px;
    max-width: 80%;
    margin: 0 auto;
    padding: 0;
    border: 0;
}
</style>

<!-- جدول التوقيعات باستخدام صفين (tr) -->
<table class="signature-table">
    <!-- الصف الأول للنصوص -->
    <tr>
        <td class="signature-texts">إعداد</td>
        <td class="signature-texts">مراجعة</td>
        <td class="signature-texts">اعتماد</td>
    </tr>

    <!-- الصف الثاني للتوقيعات -->
    <tr>
        <td class="signature-images">
            <img t-if="docs[0].finance_assign" t-att-src="image_data_uri(docs[0].finance_assign)"/>
        </td>
        <td class="signature-images">
            <img t-if="docs[0].manager_assign" t-att-src="image_data_uri(docs[0].manager_assign)"/>
        </td>
        <td class="signature-images">
            <!-- صورة اعتماد لو موجودة -->
        </td>
    </tr>
</table>
                  
        </t>
    </template>
</odoo>
