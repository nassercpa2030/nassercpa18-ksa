<t t-name="kbi_custom.report_tax_invoice_document">
    <t t-call="kbi_custom.external_layout_custom">
        <t t-foreach="docs" t-as="o">
            <div class="page">
                <link rel="stylesheet" href="/kbi_custom/static/src/css/style.css"/>

                <t t-set="company" t-value="o.company_id"/>

                <div style="font-family: Tahoma, Arial, sans-serif; direction: rtl; color:black;">

                    <!-- عنوان -->
                    <table style="width:100%; border:1px solid #999; margin-top:10px;">
                        <tr>
                            <td style="text-align:center; background:#DCDCDC; font-weight:bold;">
                                Tax Invoice / فاتورة ضريبية
                            </td>
                        </tr>
                    </table>

                    <!-- بيانات أعلى الفاتورة -->
                    <div class="row" style="margin-top:10px;">
                        <div class="col-6">
                            <strong t-esc="company.name"/><br/>
                            السجل التجاري: <span t-esc="company.company_registry or '-'"/><br/>
                            الرقم الضريبي: <span t-esc="company.vat or '-'"/>
                        </div>

                        <div class="col-4">
                            <strong>Invoice Number:</strong> <span t-field="o.name"/><br/>
                            <strong>Invoice Date:</strong> <span t-field="o.invoice_date"/><br/>
                            <strong>Payment Terms:</strong> <span t-field="o.invoice_payment_term_id"/>
                        </div>

                        <div class="col-2" style="text-align:center;">
                            <img t-if="o.get_qr_code_knk()"
                                 t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=110&amp;height=110' % o.get_qr_code_knk()"/>
                        </div>
                    </div>

                    <!-- بيانات العميل -->
                    <table style="width:100%; border:1px solid #999; margin-top:10px;">
                        <tr>
                            <td style="padding:5px;">
                                <strong>فاتورة إلى:</strong><br/>
                                الاسم: <span t-field="o.partner_id.name"/><br/>
                                العنوان: <span t-field="o.partner_id.street"/><br/>
                                السجل التجاري: <span t-field="o.partner_id.company_registry"/><br/>
                                الرقم الضريبي: <span t-field="o.partner_id.vat"/>
                            </td>
                        </tr>
                    </table>

                    <!-- جدول الأصناف -->
                    <table style="width:100%; border-collapse:collapse; margin-top:10px;" border="1">
                        <thead style="background:#DCDCDC;">
                            <tr>
                                <th>الوصف<br/>Description</th>
                                <th>سعر الوحدة<br/>Unit Price</th>
                                <th>الكمية<br/>Qty</th>
                                <th>المبلغ الخاضع<br/>Taxable</th>
                                <th>الضريبة %<br/>VAT %</th>
                                <th>قيمة الضريبة<br/>VAT</th>
                                <th>الإجمالي<br/>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="tax_total" t-value="0.0"/>
                            <tr t-foreach="o.invoice_line_ids" t-as="l">
                                <t t-set="line_tax"
                                   t-value="sum(l.price_subtotal * t.amount / 100 for t in l.tax_ids)"/>
                                <t t-set="tax_total" t-value="tax_total + line_tax"/>

                                <td t-field="l.name"/>
                                <td t-field="l.price_unit"
                                    t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                <td t-esc="l.quantity"/>
                                <td t-field="l.price_subtotal"
                                    t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                <td>
                                    <t t-foreach="l.tax_ids" t-as="t">
                                        <span t-esc="t.amount"/>%
                                    </t>
                                </td>
                                <td t-esc="line_tax"
                                    t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                <td t-field="l.price_total"
                                    t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                            </tr>
                        </tbody>
                    </table>

                    <!-- الإجماليات -->
                    <table style="width:100%; margin-top:10px;" border="1">
                        <tr>
                            <td>الإجمالي بدون ضريبة</td>
                            <td t-field="o.amount_untaxed"
                                t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                        </tr>
                        <tr>
                            <td>إجمالي الضريبة</td>
                            <td t-esc="tax_total"
                                t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                        </tr>
                        <tr style="font-weight:bold;">
                            <td>إجمالي المبلغ المستحق</td>
                            <td t-field="o.amount_total"
                                t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                        </tr>
                    </table>

                    <!-- المبلغ كتابة -->
                    <table style="width:100%; margin-top:5px;" border="1">
                        <tr>
                            <td style="background:#DCDCDC;">AMOUNT IN WORDS</td>
                            <td t-esc="o.amount_word(o.amount_total)"/>
                        </tr>
                    </table>

                    <!-- توقيعات -->
                    <div style="margin-top:20px;">
                        <strong>Prepared By:</strong> _____________ &nbsp;&nbsp;
                        <strong>Received By:</strong> _____________
                    </div>

                </div>
            </div>
        </t>
    </t>
</t>
