<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- تعريف التقرير -->
    <record id="action_report_customer_bill_template" model="ir.actions.report">
        <field name="name">فاتورة ضريبية جديدة</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_bill_template</field>
        <field name="print_report_name">'فاتورة عميل.pdf'</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- القالب -->
    <template id="report_customer_bill_template">
        <t t-set="company" t-value="docs[0].company_id"/>
        <main>
            <div class="page">
                <!-- Header مخصص -->
                <div style="display:flex; justify-content:space-between; margin-bottom:20px; font-size:10px; direction: rtl;">
                    <div style="text-align:left;">
                        <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % company.logo"
                             style="max-height:60px; max-width:150px; object-fit:contain; margin-bottom:5px;"/>
                        <p style="margin:0;">
                            <strong t-esc="company.name"/>
                            <br/> السجل التجاري: <span t-esc="company.company_registry or '-'"/>
                            <br/> الرقم الضريبي: <span t-esc="company.vat or '-'"/>
                            <br/> العنوان: <span t-esc="company.street or '-'"/>
                        </p>
                    </div>
                    <div style="text-align:right;">
                        <p>
                            <strong>فاتورة إلى:</strong>
                            <br/> الاسم: <span t-esc="docs[0].partner_id.name"/>
                            <br/> العنوان: <span t-esc="docs[0].partner_id.street or '-'"/>
                            <br/> السجل التجاري: <span t-esc="docs[0].partner_id.company_registry or '-'"/>
                            <br/> الرقم الضريبي (VAT): <span t-esc="docs[0].partner_id.vat or '-'"/>
                            <br/><strong>رقم الفاتورة:</strong> <span t-esc="docs[0].name"/>
                            <br/><strong>تاريخ الفاتورة:</strong> <span t-esc="docs[0].invoice_date"/>
                        </p>
                    </div>
                </div>

                <hr/>

                <!-- جدول الفواتير -->
                <table class="table table-bordered" style="width:100%; direction: rtl; font-size:10px; border-collapse:collapse;">
                    <thead style="background-color:#f0f0f0;">
                        <tr>
                            <th>رقم الفاتورة</th>
                            <th>أسم العميل</th>
                            <th>أمر البيع</th>
                            <th>إسم المشروع</th>
                            <th>قيمة العقد</th>
                            <th>نسبة العمولة</th>
                            <th>قيمة فاتورة المسوق</th>
                            <th>المبلغ المستحق</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="total_sum" t-value="0.0"/>
                        <t t-set="amount_residual_sig" t-value="0.0"/>
                        <t t-foreach="docs" t-as="bill">
                            <tr>
                                <td><span t-field="bill.name"/></td>
                                <td><span t-field="bill.sale_order_id_finance.partner_id.name" t-if="bill.sale_order_id_finance"/></td>
                                <td><span t-field="bill.sale_order_id_finance.name" t-if="bill.sale_order_id_finance"/></td>
