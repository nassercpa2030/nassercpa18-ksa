<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_report_customer_bill_template" model="ir.actions.report">
        <field name="name">فاتورة ضريبية</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_bill_template</field>
        <field name="print_report_name">'فاتورة ضريبية.pdf'</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_customer_bill_template">

        <t t-set="company" t-value="docs[0].company_id"/>

        <main style="
            direction: rtl;
            font-family: Tahoma, Arial, sans-serif;
            font-size: 11px;
            unicode-bidi: embed;
        ">
            <div class="page">

                <!-- بيانات الشركة -->
                <div style="text-align:center; margin-bottom:10px;">
                    <strong t-esc="company.name"/>
                    <br/>
                    السجل التجاري: <span t-esc="company.company_registry or '-'"/>
                    <br/>
                    الرقم الضريبي: <span t-esc="company.vat or '-'"/>
                </div>

                <hr/>

                <!-- بيانات العميل -->
                <div style="margin-bottom:10px;">
                    <strong>فاتورة إلى:</strong><br/>
                    الاسم: <span t-esc="docs[0].partner_id.name"/><br/>
                    العنوان: <span t-esc="docs[0].partner_id.street or '-'"/><br/>
                    السجل التجاري: <span t-esc="docs[0].partner_id.company_registry or '-'"/><br/>
                    الرقم الضريبي: <span t-esc="docs[0].partner_id.vat or '-'"/><br/>
                    رقم الفاتورة: <span t-esc="docs[0].name"/><br/>
                    تاريخ الفاتورة: <span t-esc="docs[0].invoice_date"/>
                </div>

                <hr/>

                <!-- جدول البيانات -->
                <table style="width:100%; border-collapse:collapse;" border="1">
                    <thead style="background:#f2f2f2;">
                        <tr>
                            <th>رقم الفاتورة</th>
                            <th>اسم العميل</th>
                            <th>أمر البيع</th>
                            <th>اسم المشروع</th>
                            <th>قيمة العقد</th>
                            <th>نسبة العمولة</th>
                            <th>قيمة الفاتورة</th>
                            <th>المبلغ المستحق</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="total" t-value="0.0"/>
                        <t t-set="residual" t-value="0.0"/>

                        <t t-foreach="docs" t-as="o">
                            <tr>
                                <td t-esc="o.name"/>
                                <td t-esc="o.partner_id.name"/>
                                <td t-esc="o.invoice_origin or '-'"/>
                                <td t-esc="o.invoice_line_ids[0].name if o.invoice_line_ids else '-'"/>
                                <td t-esc="o.amount_untaxed"/> SR
                                <td>—</td>
                                <td t-esc="o.amount_total"/> SR
                                <td t-esc="o.amount_residual"/> SR

                                <t t-set="total" t-value="total + o.amount_total"/>
                                <t t-set="residual" t-value="residual + o.amount_residual"/>
                            </tr>
                        </t>

                        <tr style="font-weight:bold;">
                            <td colspan="7">إجمالي المبلغ المستحق</td>
                            <td t-esc="residual"/> SR
                        </tr>
                        <tr style="font-weight:bold;">
                            <td colspan="7">إجمالي المبالغ</td>
                            <td t-esc="total"/> SR
                        </tr>
                    </tbody>
                </table>

                <hr/>

                <!-- ملخص -->
                <div>
                    المجموع بدون ضريبة: <span t-esc="docs[0].amount_untaxed"/> SR<br/>
                    الضريبة (15%): <span t-esc="docs[0].amount_tax"/> SR<br/>
                    <strong>الإجمالي: <span t-esc="docs[0].amount_total"/> SR</strong>
                </div>

                <br/>

                <!-- QR -->
                <div style="text-align:center;">
                    <img t-if="docs[0].get_qr_code_knk()"
                         t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=120&amp;height=120' % docs[0].get_qr_code_knk()"/>
                    <div>Scan for ZATCA</div>
                </div>

                <hr/>

                <!-- Footer -->
                <div style="text-align:center; font-size:9px;">
                    الهاتف: <span t-esc="company.phone or '-'"/> |
                    البريد: <span t-esc="company.email or '-'"/> |
                    الموقع: <span t-esc="company.website or '-'"/>
                    <br/>
                    فاتورة ضريبية مطابقة لمتطلبات هيئة الزكاة والضريبة والجمارك
                </div>

            </div>
        </main>
    </template>
</odoo>
