<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- تعريف تقرير وربطه بنموذج فواتير العملاء -->
    <record id="action_report_customer_bill_template_custom" model="ir.actions.report">
        <field name="name">فاتورة ضريبية مخصصة</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_customer_bill_template_custom</field>
        <field name="print_report_name">'فاتورة عميل.pdf'</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- قالب QWeb لتصميم شكل التقرير -->
    <template id="report_customer_bill_template_custom">
        <t t-set="company" t-value="docs[0].company_id"/>
        <t t-call="web.external_layout_standard">
            <div class="page" style="">
                <link rel="stylesheet" href="/kbi_custom/static/src/css/style.css"/>
                <div class="font">
                    <!-- عنوان الفاتورة -->
                    <table style="border:1pt solid grey;width:100%; height: 23px;color:black; margin-top:10pt;" class="table-condensed table-sm">
                        <tr>
                            <td style="padding:1pt;margin:0pt;font-weight: bold;text-align:center;background-color:#DCDCDC;">
                                <span class="text-right arabic">Tax Invoice / فاتورة ضريبية </span>
                            </td>
                        </tr>
                    </table>

                    <!-- بيانات العميل والفاتورة -->
                    <div class="row" style="margin-top:10px;">
                        <div class="col-6" name="invoice_address">
                            <address t-field="docs[0].partner_id" t-options='{"widget": "contact", "fields": ["address","name"], "no_marker": true}'/>
                            <div t-if="docs[0].partner_id.vat" class="mt16">
                                <t t-esc="company.country_id.vat_label or 'TIN'"/>: <span t-field="docs[0].partner_id.vat"/>
                            </div>
                        </div>
                        <div class="col-4" style="margin-top:50px;">
                            <p>
                                <strong>Invoice Number: </strong><span t-field="docs[0].name"/><br/>
                                <strong>Invoice Date: </strong><span t-field="docs[0].invoice_date"/><br/>
                                <strong>Payment Terms: </strong><span t-field="docs[0].invoice_payment_term_id"/><br/>
                            </p>
                        </div>
                        <div class="col-2">
                            <img t-if="docs[0].get_qr_code_knk()" style="display:block;"
                                 t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=110&amp;height=110' % docs[0].get_qr_code_knk()"/>
                        </div>
                    </div>

                    <!-- جدول البنود -->
                    <table style="border:1pt solid grey;width:100%; margin-top:10px;" class="table-condensed">
                        <thead>
                            <tr style="background-color:#DCDCDC; text-align:center;">
                                <td>Description<br/><span class="arabic">تفاصيل السلع أو الخدمات</span></td>
                                <td>Unit Price<br/><span class="arabic">سعر الوحدة</span></td>
                                <td>Quantity<br/><span class="arabic">الكمية</span></td>
                                <td>Taxable Amount<br/><span class="arabic">المبلغ الخاضع للضريبة</span></td>
                                <td>Discount<br/><span class="arabic">خصومات</span></td>
                                <td>Tax Rate<br/><span class="arabic">نسبة الضريبة</span></td>
                                <td>Tax Amount<br/><span class="arabic">مبلغ الضريبة</span></td>
                                <td>Total (incl.vat)<br/><span class="arabic">المجموع (شامل ضريبة القيمة المضافة)</span></td>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="tax_total" t-value="0"/>
                            <t t-set="discount_total" t-value="0"/>
                            <tr t-foreach="docs[0].invoice_line_ids" t-as="l">
                                <t t-set="line_tax_total" t-value="0"/>
                                <t t-foreach="l.tax_ids" t-as="t">
                                    <t t-set="tax_total" t-value="tax_total + l.price_subtotal * t.amount / 100"/>
                                    <t t-set="line_tax_total" t-value="line_tax_total + t.amount"/>
                                </t>
                                <t t-set="discount_total" t-value="discount_total + ((l.price_unit * l.quantity) - l.price_subtotal)"/>
                                <td><span t-field="l.name"/></td>
                                <td style="text-align:right;"><span t-field="l.price_unit" t-options='{"widget": "monetary", "display_currency": docs[0].currency_id}'/></td>
                                <td style="text-align:center;"><span t-esc="'%.2f %s' % (l.quantity,l.product_uom_id.name)"/></td>
                                <td style="text-align:right;"><span t-esc="l.price_unit * l.quantity" t-options='{"widget":"monetary","display_currency": docs[0].currency_id}'/></td>
                                <td style="text-align:right;"><span t-field="l.discount"/> %</td>
                                <td style="text-align:center;">
                                    <t t-foreach="l.tax_ids" t-as="t">
                                        <span t-esc="'%.2f' % t.amount"/> %
                                    </t>
                                </td>
                                <td style="text-align:right;"><span t-esc="l.price_subtotal * line_tax_total / 100" t-options='{"widget":"monetary","display_currency": docs[0].currency_id}'/></td>
                                <td style="text-align:right;"><span t-field="l.price_subtotal" t-options='{"widget":"monetary","display_currency": docs[0].currency_id}'/></td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ملخص المبالغ -->
                    <table style="width:100%; margin-top:10px;" class="table table-bordered table-sm">
                        <tr>
                            <td>Total (Excl. VAT)</td>
                            <td><span t-esc="docs[0].amount_untaxed" t-options='{"widget":"monetary","display_currency": docs[0].currency_id}'/></td>
                        </tr>
                        <tr>
                            <td>Total VAT</td>
                            <td><span t-esc="tax_total" t-options='{"widget":"monetary","display_currency": docs[0].currency_id}'/></td>
                        </tr>
                        <tr>
                            <td>Total Amount Due</td>
                            <td><span t-esc="docs[0].amount_residual" t-options='{"widget":"monetary","display_currency": docs[0].currency_id}'/></td>
                        </tr>
                    </table>

                    <!-- Footer + توقيع -->
                    <div style="margin-top:20px; font-size:9px; text-align:center;">
                        <p>الهاتف: <span t-esc="company.phone or '-'"/> | البريد الإلكتروني: <span t-esc="company.email or '-'"/></p>
                        <p>فاتورة ضريبية صادرة وفق متطلبات ZATCA</p>
                        <div style="display:flex; justify-content:space-between; margin-top:10px;">
                            <div>إعداد: ________________</div>
                            <div>مراجعة: ________________</div>
                            <div>إعتماد: ________________</div>
                        </div>
                    </div>

                </div>
            </div>
        </t>
    </template>

</odoo>
