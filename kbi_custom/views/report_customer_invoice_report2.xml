<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_customer_bill_template" model="ir.actions.report">
        <field name="name">فاتورة ضريبية</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_tax_invoice_document</field>
        <field name="print_report_name">
            f"فاتورة - {object.name or ''} - {object.sale_order_id_finance.partner_id.name or ''} - {object.sale_order_id_finance.name or ''}"
        </field>
        <field name="paperformat_id" ref="kbi_custom.paperformat_zero_margin"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_tax_invoice_document">
        <t t-foreach="docs" t-as="o">
            <t t-call="kbi_custom.external_layout_seti">

                <!-- ================= STYLE ================= -->
                <style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&amp;display=swap');

body, table, td, th {
    font-family: 'Tajawal', sans-serif;
    font-size: 13px;
}

table {
    width: 100%;
    border-collapse: collapse;
}

td, th {
    padding: 5px;
    border: 1px solid #2F6FB2;
    text-align: right;
}

th {
    font-weight: bold;
    font-size: 13.5px;
    background: #EAF3FF;
}

/* عناصر بدون بوردر */
.no-print-border {
    border: none !important;
}

/* عناصر ببوردر إجباري */
.force-border {
    border: 1.5px solid #2F6FB2 !important;
}

/* ================= الطباعة فقط ================= */
@media print {

    table[style*="border:none"],
    table[style*="border:0"],
    td[style*="border:none"],
    td[style*="border:0"],
    th[style*="border:none"],
    th[style*="border:0"],
    div[style*="border:none"],
    div[style*="border:0"],
    img[style*="border:none"],
    img[style*="border:0"],
    .no-print-border {
        border: none !important;
        outline: none !important;
        box-shadow: none !important;
    }

    table, td, th {
        outline: none !important;
        box-shadow: none !important;
    }
}

.thank-you {
    text-align: center;
    font-size: 12px;
}
.thank-you .decor {
    color: #c71585;
    margin-top: 5px;
    letter-spacing: 2px;
}
                </style>

                <!-- ================= BODY ================= -->
                <div class="page" style="margin:0; padding:0 0 180px 0;">

                    <!-- عنوان الفاتورة -->
                    <table>
                        <tr>
                            <td colspan="8" style="text-align:center;font-weight:bold;">
                                فاتورة ضريبية
                            </td>
                            <td colspan="8" style="text-align:center;font-weight:bold; direction:ltr;">
                                Tax Invoice
                            </td>
                        </tr>
                    </table>

                    <!-- بيانات الفاتورة -->
                    <table style="margin-top:12px;">
                        <tr>
                            <td class="no-print-border">
                                <table>
                                    <tr>
                                        <td width="33%"><strong>رقم الفاتورة</strong></td>
                                        <td width="34%" style="text-align:center;"><span t-field="o.name"/></td>
                                        <td width="33%" style="text-align:left;"><strong>Invoice No</strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>المصدر</strong></td>
                                        <td style="text-align:center;"><span t-field="o.sale_order_id_finance.name"/></td>
                                        <td style="text-align:left;"><strong>Source</strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>كود المصدر</strong></td>
                                        <td style="text-align:center;"><span t-field="o.sale_order_id_finance.auto_code"/></td>
                                        <td style="text-align:left;"><strong>Source Code</strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>التاريخ</strong></td>
                                        <td style="text-align:center;"><span t-field="o.invoice_date"/></td>
                                        <td style="text-align:left;"><strong>Date</strong></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <!-- جدول البنود -->
                    <table style="margin-top:15px;">
                        <thead>
                            <tr>
                                <th>الوصف<br/>Description</th>
                                <th>الخدمة المقدمة<br/>Service</th>
                                <th>Qty</th>
                                <th>Unit Price</th>
                                <th>Subtotal</th>
                                <th>VAT %</th>
                                <th>VAT</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="tax_total" t-value="0"/>
                            <tr t-foreach="o.invoice_line_ids" t-as="l">
                                <t t-set="line_tax" t-value="sum(t.amount for t in l.tax_ids)"/>
                                <t t-set="line_tax_amount" t-value="l.price_subtotal * line_tax / 100"/>
                                <t t-set="tax_total" t-value="tax_total + line_tax_amount"/>

                                <td><span t-field="l.name"/></td>
                                <td>
                                    <t t-esc="l.sale_line_ids and l.sale_line_ids[0].order_id.project_name or ''"/>
                                </td>
                                <td style="text-align:center;"><span t-field="l.quantity"/></td>
                                <td style="text-align:center;">
                                    <span t-field="l.price_unit"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                                <td style="text-align:center;">
                                    <span t-field="l.price_subtotal"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                                <td style="text-align:center;"><t t-esc="line_tax"/>%</td>
                                <td style="text-align:center;">
                                    <span t-esc="line_tax_amount"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                                <td style="text-align:center; font-weight:bold;">
                                    <span t-esc="l.price_subtotal + line_tax_amount"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- الإجماليات + QR -->
                    <table style="margin-top:20px; border:none;">
                        <tr>

                            <!-- الإجماليات -->
                            <td width="60%" class="no-print-border">
                                <table class="force-border">
                                    <tr>
                                        <td>الإجمالي قبل الضريبة</td>
                                        <td style="text-align:right;">
                                            <span t-field="o.amount_untaxed"
                                                  t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                        </td>
                                        <td style="text-align:left;">Subtotal</td>
                                    </tr>
                                    <tr>
                                        <td>الضريبة</td>
                                        <td style="text-align:right;">
                                            <span t-esc="tax_total"
                                                  t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                        </td>
                                        <td style="text-align:left;">VAT</td>
                                    </tr>
                                    <tr style="font-weight:bold; background:#EAF3FF;">
                                        <td>المجموع الكلي</td>
                                        <td style="text-align:right;">
                                            <span t-field="o.amount_total"
                                                  t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                        </td>
                                        <td style="text-align:left;">Total Amount</td>
                                    </tr>
                                </table>
                            </td>

                            <!-- QR -->
                            <td width="40%" class="no-print-border" style="text-align:center;">
                                <t t-if="o.get_qr_code()">
                                    <div class="force-border" style="display:inline-block; padding:6px;">
                                        <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=150&amp;height=150' % o.get_qr_code()"
                                             style="width:120px; height:120px;"/>
                                    </div>
                                </t>
                            </td>

                        </tr>
                    </table>

                    <!-- ملاحظة -->
                    <div style="margin-top:30px; font-size:11px;">
                        فاتورة ضريبية صادرة وفق متطلبات هيئة الزكاة والضريبة والجمارك (ZATCA)<br/>
                        Tax Invoice issued in accordance with ZATCA requirements
                    </div>

                    <!-- شكر -->
                    <div class="thank-you" style="margin-top:40px;">
                        <strong>🌸🌸🌸 نشكركم علي التعامل معنا / Thank you 🌸🌸🌸</strong>
                        <div class="decor">❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀ ❀</div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
