<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Report Action -->
    <!-- ============================= -->
    <record id="action_report_tax_invoice_kbi" model="ir.actions.report">
        <field name="name">فاتورة عميل ضريبية</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report_tax_invoice_document</field>
        <field name="report_file">kbi_custom.report_tax_invoice_document</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================= -->
    <!-- QWEB REPORT -->
    <!-- ============================= -->
    <template id="report_tax_invoice_document">
        <t t-call="kbi_custom.external_layout_seti">
            <t t-foreach="docs" t-as="o">

                <div class="page" style="margin:0; padding:0;">
                    <link rel="stylesheet" href="/kbi_custom/static/src/css/style.css"/>

                    <!-- عنوان الفاتورة -->
                    <table style="width:100%;border:1px solid #999;margin-top:10px;">
                        <tr>
                            <td style="text-align:center;font-weight:bold;background:#DCDCDC;padding:5px;">
                                Tax Invoice / فاتورة ضريبية
                            </td>
                        </tr>
                    </table>

                    <!-- بيانات الشركة + QR -->
                    <div class="row" style="margin-top:10px;">
                        <div class="col-7">
                            <strong><span t-field="o.company_id.name"/></strong><br/>
                            CR: <span t-field="o.company_id.company_registry"/><br/>
                            VAT: <span t-field="o.company_id.vat"/>
                        </div>
                        <div class="col-5 text-end">
                            <img t-if="o.get_qr_code()"
                                 t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=120&amp;height=120' % o.get_qr_code()"/>
                        </div>
                    </div>

                    <!-- بيانات العميل -->
                    <table style="width:100%;margin-top:10px;">
                        <tr>
                            <td width="50%">
                                <strong>Invoice To:</strong><br/>
                                <span t-field="o.partner_id.name"/><br/>
                                <span t-field="o.partner_id.street"/><br/>
                                VAT: <span t-field="o.partner_id.vat"/>
                            </td>
                            <td width="50%">
                                Invoice No: <strong><span t-field="o.name"/></strong><br/>
                                Date: <span t-field="o.invoice_date"/><br/>
                                Payment Terms: <span t-field="o.invoice_payment_term_id.name"/>
                            </td>
                        </tr>
                    </table>

                    <!-- جدول البنود -->
                    <table class="table table-bordered" style="width:100%;margin-top:15px;">
                        <thead style="background:#DCDCDC;">
                            <tr>
                                <th>Description<br/>الوصف</th>
                                <th>Qty<br/>الكمية</th>
                                <th>Unit Price<br/>سعر الوحدة</th>
                                <th>Subtotal<br/>المجموع</th>
                                <th>VAT %</th>
                                <th>VAT Amount</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="tax_total" t-value="0"/>
                            <tr t-foreach="o.invoice_line_ids" t-as="l">
                                <t t-set="line_tax" t-value="sum(t.amount for t in l.tax_ids)"/>
                                <t t-set="line_tax_amount" t-value="l.price_subtotal * line_tax / 100"/>
                                <t t-set="tax_total" t-value="tax_total + line_tax_amount"/>

                                <td>
                                    <span t-field="l.name"/>
                                </td>
                                <td class="text-center">
                                    <span t-field="l.quantity"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="l.price_unit"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="l.price_subtotal"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                                <td class="text-center">
                                    <span t-esc="line_tax"/>%
                                </td>
                                <td class="text-end">
                                    <span t-esc="line_tax_amount"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="l.price_subtotal + line_tax_amount"
                                          t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- الإجماليات -->
                    <table class="table table-bordered" style="width:100%;margin-top:10px;">
                        <tr>
                            <td>Subtotal (Excl. VAT)</td>
                            <td class="text-end">
                                <span t-field="o.amount_untaxed"
                                      t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                            </td>
                        </tr>
                        <tr>
                            <td>VAT 15%</td>
                            <td class="text-end">
                                <span t-esc="tax_total"
                                      t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                            </td>
                        </tr>
                        <tr style="font-weight:bold;">
                            <td>Total Amount</td>
                            <td class="text-end">
                                <span t-field="o.amount_total"
                                      t-options="{'widget':'monetary','display_currency':o.currency_id}"/>
                            </td>
                        </tr>
                    </table>

                    <p style="margin-top:10px;font-size:11px;">
                        فاتورة ضريبية صادرة وفق متطلبات هيئة الزكاة والضريبة والجمارك (ZATCA)
                    </p>

                </div>
            </t>
        </t>
    </template>

</odoo>
