<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- تعريف التقرير -->
    <record id="action_motalba_report" model="ir.actions.report">
        <field name="name">مطالبة بكامل المبلغ</field>
       <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kbi_custom.report__motalba_report_template</field>
        <field name="print_report_name">'مطالبة بكامل المبلغ.pdf'</field>
       <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- قالب التقرير -->
    <template id="report__motalba_report_template">
        <t t-set="company" t-value="docs[0].company_id"/>
        <t t-call="web.html_container">
            <!-- استخدام التخطيط القياسي لإضافة رأس الشركة وتذييلها وأرقام الصفحات -->
            <t t-call="web.external_layout_standard">
                <div class="page" style="direction: rtl; text-align: right; font-family: 'Noto Sans Arabic', sans-serif;">

                    <!-- عنوان التقرير -->
                    <h2 style="text-align: center;">مطالبة عميل </h2>
                   
                    
                    <hr/>

                    <!-- معلومات المورد (سنفترض أن كل الفواتير المحددة لنفس المورد) -->
                        <div style=" direction: rtl;">
                            <p style=" text-align:right; ">
                        التاريخ: 
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d ')"/>
                    </p>
                        <p style=" text-align:right;">
                            العميل: <span t-field="docs[0].partner_id.name"/>
                        </p>
                        <p style=" text-align:right;">
                            رقم الأوردر: <span t-field="docs[0].name"/>
                        </p>
                           <p style=" text-align:right;">
                        كود النظام : <span t-field="docs[0].auto_code"/>
                        </p>
                    </div>

                    <hr/>

                    <!-- الجدول الرئيسي للبيانات -->
                     <table class="table table-bordered" style="width: 100%; direction: rtl; font-size: 10px;">
                        <thead style="background-color: #f0f0f0;">
                            <tr>
                                <th style="padding: 8px; text-align: center;"><h4> الوصف </h4></th>
                                <th style="padding: 8px; text-align: center;"><h4> القيمة قبل الضريبة</h4> </th>
                                <th style="padding: 8px; text-align: center;"><h4>الضريبة </h4></th>
                                <th style="padding: 8px; text-align: center;"><h4>القيمة بعد  الضريبة</h4> </th>

                            </tr>
                        </thead>
                        <tbody>
                            <!-- تهيئة متغير المجموع -->
                            <t t-set="total_sum" t-value="0.0"/> 

                            <!-- المرور على جميع الفواتير -->
                            <t t-foreach="docs" t-as="bill">
                                <tr>
                                    <td style="padding: 8px;"> <h6> <span t-field="bill.project_name"/></h6></td>
                                    <td style="padding: 8px;"><h6><span t-field="bill.amount_untaxed"/></h6></td>
                                 
                                    <td style="padding: 7px; text-align: center;"><h6><span t-field="bill.amount_tax"/>   <b>SR</b></h6></td>

                                    <td style="padding: 10px; text-align: center;"><h6><span t-field="bill.amount_total"/></h6></td>
                                   
                                  
                                </tr>
                             
                            </t>

                        </tbody>
                    </table>

                    <hr/>

                    <!-- كتعة التوقيعات -->
                    <table style="width: 100%; text-align: center; background-color: #f0f0f0;">
                          
                        <tr>
                           <td style="width: 33%;"><strong>إجمالي المطلوب</strong></td>
                            <td style="width: 33%;"><strong></strong></td>
                            <!--td style="width: 33%;"><strong></strong></td-->
                            <td style="padding: 8px; text-align: left;">
                                       <strong> <span t-field="bill.amount_total" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: bill.currency_id}"/></strong>
                                    </td>
                        </tr>
                         
                        <tr>
                            
                            <td style="height: 50px;"></td>
                            <td style="height: 50px;"></td>
                            <td style="height: 50px;"></td>
                        </tr>      
              
                        <!--tr><h2 style="text-align: center;"><span t-field="bill.amount_total"/></h2></tr-->
                    </table>
                    <hr/>
                                <table style="width: 100%; text-align: center;" >
                          
                     
                         
                        <tr>
                            
                            <td style="height: 50px;"></td>
                            <td style="height: 100px;"><span t-field="bill.sign_qrcode"/></td>
                            <td style="height: 50px;"></td>
                        </tr>      
              
                        <!--tr><h2 style="text-align: center;"><span t-field="bill.amount_total"/></h2></tr-->
                    </table>

                </div>
            </t>
        </t>
    </template>
</odoo>
