<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- تعريف التقرير -->
    <record id="action_vendor_bill_batch_report" model="ir.actions.report">
        <field name="name">طلب صرف عمولة مسوق</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_vendor_report.report_broker_payment_template</field>
        <field name="report_file_name">طلب_صرف_عمولة.pdf</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- قالب التقرير -->
    <template id="report_broker_payment_template">
        <t t-call="web.html_container">
            <!-- استخدام التخطيط القياسي لإضافة رأس الشركة وتذييلها وأرقام الصفحات -->
            <t t-call="web.external_layout_standard">
                <div class="page" style="direction: rtl; text-align: right; font-family: 'Noto Sans Arabic', sans-serif;">

                    <!-- عنوان التقرير -->
                    <h2 style="text-align: center;">Project AutoCode</h2>
                    <h3 style="text-align: center;">طلب صرف عمولة مسوق بالقطعة</h3>
                    
                    <hr/>

                    <!-- معلومات المورد (سنفترض أن كل الفواتير المحددة لنفس المورد) -->
                    <div style="margin-bottom: 20px;">
                        <strong>اسم المورد:</strong> 
                        <span t-field="docs[0].partner_id.name"/><br/>
                        
                        <strong>هاتف المورد:</strong> 
                        <span t-field="docs[0].partner_id.phone"/><br/>
                        
                        <strong>رقم حساب المورد:</strong> 
                        <!-- هذا الحقل قد يكون custom field، يمكنك تعديله -->
                        <span t-field="docs[0].partner_id.bank_ids[0].acc_number"/>
                        
                        <div style="text-align: left; margin-top: 10px;">
                            <strong>التاريخ:</strong> 
                            <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/>
                        </div>
                    </div>

                    <hr/>

                    <!-- الجدول الرئيسي للبيانات -->
                    <table class="table table-bordered" style="width: 100%; margin-bottom: 30px;">
                        <thead style="background-color: #f2f2f2;">
                            <tr>
                                <th style="padding: 10px; text-align: center;">إسم العميل</th>
                                <th style="padding: 10px; text-align: center;">إسم العقد</th>
                                <th style="padding: 10px; text-align: center;">قيمة العقد قبل الضريبة</th>
                                <th style="padding: 10px; text-align: center;">قيمة فاتورة المسوق</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- المرور على كل فاتورة محددة -->
                            <t t-foreach="docs" t-as="o">
                                <tr>
                                    <td style="padding: 8px;">
                                        <span t-field="o.partner_id.name"/>
                                    </td>
                                    <td style="padding: 8px;">
                                        <!-- ملاحظة: قد تحتاج لتغيير هذا الحقل حسب نظامك -->
                                        <span t-field="o.ref"/>
                                    </td>
                                    <td style="padding: 8px; text-align: left;">
                                        <span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                    <td style="padding: 8px; text-align: left;">
                                        <!-- ملاحظة: هذا حقل افتراضي، يجب إنشاؤه أو تغييره -->
                                        <span t-field="o.x_broker_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <hr/>

                    <!-- كتعة التوقيعات -->
                    <table style="width: 100%; text-align: center;">
                        <tr>
                            <td style="width: 33%;"><strong>إعداد</strong></td>
                            <td style="width: 33%;"><strong>مراجعة</strong></td>
                            <td style="width: 33%;"><strong>إعتماد</strong></td>
                        </tr>
                        <tr>
                            <td style="height: 50px;"></td>
                            <td style="height: 50px;"></td>
                            <td style="height: 50px;"></td>
                        </tr>
                    </table>

                </div>
            </t>
        </t>
    </template>
</odoo>