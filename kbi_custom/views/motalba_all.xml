<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- تعريف التقرير -->
    <record id="action_motalba_report" model="ir.actions.report">
        <field name="name">مطالبة بكامل المبلغ</field>
       <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_vendor_report.report_broker_payment_template</field>
        <field name="report_file_name">مطالبة بكامل المبلغ.pdf</field>
       <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- قالب التقرير -->
    <template id="report__motalba_report_template">
        <t t-call="web.html_container">
            <!-- استخدام التخطيط القياسي لإضافة رأس الشركة وتذييلها وأرقام الصفحات -->
            <t t-call="web.external_layout_standard">
                <div class="page" style="direction: rtl; text-align: right; font-family: 'Noto Sans Arabic', sans-serif;">

                    <!-- عنوان التقرير -->
                    <h2 style="text-align: center;">Project AutoCode</h2>
                    <h3 style="text-align: center;">طلب صرف عمولة مسوق بالقطعة</h3>
                    
                    <hr/>

                    <!-- معلومات المورد (سنفترض أن كل الفواتير المحددة لنفس المورد) -->
                        <div style=" direction: rtl;">
                            <p style=" text-align:right; font-size:10px;">
                        التاريخ: 
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d ')"/>
                    </p>
                        <p style=" text-align:right;">
                            العميل: <span t-field="docs[0].partner_id.name"/>
                        </p>
                        <p style=" text-align:right;">
                            رقم الأوردر: <span t-field="docs[0].name"/>
                        </p>
                           <p style=" text-align:right;">
                        كود النظام : <span t-field="docs[0].auto_code"/>
                        </p>
                    </div>

                    <hr/>

                    <!-- الجدول الرئيسي للبيانات -->
                     <table class="table table-bordered" style="width: 100%; direction: rtl; font-size: 10px;">
                        <thead style="background-color: #f0f0f0;">
                            <tr>
                                <th style="padding: 8px; text-align: center;"> الوصف</th>
                                <th style="padding: 8px; text-align: center;"> القيمة قبل الضريبة </th>
                                <th style="padding: 8px; text-align: center;">الضريبة </th>
                                <th style="padding: 8px; text-align: center;">القيمة بعد  الضريبة </th>
&gt;
                            </tr>
                        </thead>
                        <tbody>
                            <!-- تهيئة متغير المجموع -->
                            <t t-set="total_sum" t-value="0.0"/> 

                            <!-- المرور على جميع الفواتير -->
                            <t t-foreach="docs" t-as="bill">
                                <tr>
                                    <td style="padding: 8px;">  <span t-field="bill.project_name"/></td>
                                    <td style="padding: 8px;"><span t-field="bill.amount_untaxed"/></td>
                                 
                                    <td style="padding: 7px; text-align: center;"><span t-field="bill.amount_tax"/>   <b>%</b></td>

                                    <td style="padding: 10px; text-align: center;"><span t-field="bill.amount_total"/></td>
                                    <td style="padding: 8px; text-align: left;">
                                        <span t-field="bill.amount_total" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: bill.currency_id}"/>
                                    </td>
                                  
                                </tr>
                            </t>

                        </tbody>
                    </table>

                    <hr/>

                    <!-- كتعة التوقيعات -->
                    <table style="width: 100%; text-align: center;">
                        <tr>
                            <td style="width: 33%;"><strong>إعداد</strong></td>
                            <td style="width: 33%;"><strong>مراجعة</strong></td>
                            <td style="width: 33%;"><strong>إعتماد</strong></td>
                        </tr>
                        <tr>
                            <td style="height: 50px;"></td>
                            <td style="height: 50px;"></td>
                            <td style="height: 50px;"></td>
                        </tr>
                    </table>

                </div>
            </t>
        </t>
    </template>
</odoo>
