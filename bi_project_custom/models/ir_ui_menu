# -*- coding: utf-8 -*-
from odoo import models, api

class IrUiMenu(models.Model):
    _inherit = "ir.ui.menu"

    @api.model
    def _load_menus_blacklist(self):
        # نبدأ بالكود الأصلي من superclass
        res = super(IrUiMenu, self)._load_menus_blacklist()

        # محاولة إضافة قائمة project.menu_projects بأمان
        menu = self.env.ref('project.menu_projects', raise_if_not_found=False)
        if menu:
            res.append(menu.id)

        # لو فيه أي قوائم إضافية من موديولات أخرى يمكن إضافتها هنا بنفس الطريقة
        # مثال:
        # hr_menu = self.env.ref('hr_timesheet.menu_timesheet_root', raise_if_not_found=False)
        # if hr_menu:
        #     res.append(hr_menu.id)

        return res
