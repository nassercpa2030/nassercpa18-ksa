<odoo>
  <!-- Close Entry Deffered Wizard -->
  <record id="view_close_entry_wizard_form_deffered" model="ir.ui.view">
      <field name="name">close.entry.wizard.form.deffered</field>
      <field name="model">close.entry.wizard</field>
      <field name="arch" type="xml">
          <form string="Close Entry Deffered">
              <group>
                  <field name="journal_id1" required="1"/>
                  <field name="account_id1" required="1"/>
                   <field name="journal_entry_date" />
              </group>
              <field name="invoice_lines" widget="one2many_list" mode="list,form">
                
                  <list create="1" edit="1" delete="1">
                      <field name="product_id"/>
                      <field name="name"/>
                      <field name="account_id"/>
                      <field name="quantity"/>
                      <field name="price_unit"/>
                      <field name="total_price"/>
                  </list>
                  <form>
                      <group>
                          <field name="product_id"/>
                          <field name="name"/>
                          <field name="account_id"/>
                          <field name="quantity"/>
                          <field name="price_unit"/>
                          <field name="total_price"/>
                      </group>
                  </form>
              </field>
              <footer>
                  <button string="Close Entry Deffered" type="object" class="btn btn-warning" name="close_entry_deffered"/>
                  <button string="Cancel" class="btn btn-danger" special="cancel"/>
              </footer>
          </form>
      </field>
  </record>

  <record id="action_close_entry_wizard" model="ir.actions.act_window">
      <field name="name">Close Entry</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">close.entry.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
  </record>

  <!-- Close Entry Wizard -->
  <record id="view_close_entry_wizard_form" model="ir.ui.view">
      <field name="name">close.entry.wizard.form</field>
      <field name="model">close.entry.wizard</field>
      <field name="arch" type="xml">
          <form string="Close Entry">
              <group>
                   <field name="journal_id" invisible="use_account_id1"/>
                  <field name="journal_id2" invisible="not use_account_id1"/>
                 <!--field name="journal_id"  invisible="use_account_id1 = True"  required="use_account_id1 = False"/-->
                 <!--field name="journal_id2" invisible="use_account_id1 = False" required="use_account_id1 = True"/-->
                  <field name="account_id" required="1"/>
                   <field name="journal_entry_date" />
              </group>
              <field name="invoice_lines" widget="one2many_list" mode="list,form">
                  <list create="1" edit="1" delete="1">
                      <field name="product_id"/>
                      <field name="name"/>
                      <field name="account_id"/>
                      <field name="quantity"/>
                      <field name="price_unit"/>
                      <field name="total_price"/>
                  </list>
                  <form>
                      <group>
                          <field name="product_id"/>
                          <field name="name"/>
                          <field name="account_id"/>
                          <field name="quantity"/>
                          <field name="price_unit"/>
                          <field name="total_price"/>
                      </group>
                  </form>
              </field>
              <footer>
                  <field name="use_account_id1" widget="boolean_toggle" help="في حالة تفعيل هذا الخيار، سيتم استخدام الحساب البديل بدلاً من الحساب الأصلي في القيد."/>
                  <button string="Close Entry" type="object" name="close_entry"/>
                  <button string="Cancel" class="btn-secondary" special="cancel"/>
              </footer>
          </form>
      </field>
  </record>

  <!-- Sale Order Form Inherit -->
  <record id="view_order_form_inherit_new" model="ir.ui.view">
      <field name="name">sale.order.form.inherit_new</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
          <!--xpath expr="//field[@name='partner_shipping_id']" position="after">
              <field name="project_files_state"
                     widget="badge"
                     options='{
                         "style": {
                             "done": "background-color: #28a745; color: white; font-weight: bold;",
                             "not_done": "background-color: #dc3545; color: white; font-weight: bold;",
                             "last_done": "background-color: #ffc107; color: white; font-weight: bold;"
                         }
                     }'/>
          </xpath-->

          <xpath expr="//header" position="inside">
              <field name="is_project_close_stage" invisible="1"/>
              <field name="is_journal_state_not_posted" invisible="1"/>
             <button name="action_create_new_payment2"
                      string="Create Payment"
                      type="object"
                      icon="fa-money"
                      style="background-color:#87CEFA; color:white;"
                      class="oe_lowlight" 
                      modifiers="{'invisible': [('paid_total','>',0)]}"
               />
            
              <button name="action_close_journal_entries"
                      string="Close Entry"
                      type="object"
                      icon="fa-money"
                      class="oe_highlight"/>
              <button name="action_open_close_entry_wizard_deffered"
                      type="object"
                      string="Deffered-Rev"
                      icon="fa-money"
                      class="btn btn-warning"
                      groups="base.group_system"
                      style="background-color: orange; color: white; font-weight: bold;"/>
                 <!--div style="background-color:#a94442">
                     <button name="_action_print_mutalba_report" type="object" class="alert alert-danger" icon="fa fa-print" string="طباعة مطالبة"
                        groups="base.group_user"/>
                    </div-->
            
              <button name="action_set_not_custom_signed"
                      type="object"
                      string="Customer Not_Signed"
                      icon="fa-ban"
                      class="btn btn-info"
                      style="color: white; font-weight: bold;"
                      confirm="Are you sure you want to set this order as 'Customer Not Signed'?"/>
          </xpath>
      </field>
  </record>

  <!-- Sale Order Journal Entries Button -->
  <record id="view_order_form_inherit_journal_entries" model="ir.ui.view">
      <field name="name">sale.order.form.inherit.journal.entries</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
          <xpath expr="//button[@name='action_view_invoice']" position="before">
              <button type="object" name="action_view_journal_entries" class="oe_stat_button" icon="fa-usd">
                  <field string="Close Entries" name="journal_entry_count" widget="statinfo"/>
              </button>
          </xpath>
      </field>
  </record>

  <!-- Project Stage Route -->
  <record id="project_stage_route_view_form_inherit" model="ir.ui.view">
      <field name="name">project.stage.route.view.form.inherit</field>
      <field name="model">project.project.stage</field>
      <field name="inherit_id" ref="project.project_project_stage_view_form"/>
      <field name="arch" type="xml">
          <xpath expr="//sheet" position="inside">
              <notebook>
                  <page string="Route Rules">
                      <group>
                          <group>
                              <field name="allowed_users_ids" widget="many2many_tags"/>
                          </group>
                          <group/>
                      </group>
                      <field name="rout_rule_ids">
                          <list editable="bottom">
                              <field name="stage_id" invisible="1"/>
                              <field name="allow_stage_id"/>
                              <field name="allowed_users_ids" widget="many2many_tags"/>
                          </list>
                      </field>
                  </page>
              </notebook>
          </xpath>
      </field>
  </record>
</odoo>
